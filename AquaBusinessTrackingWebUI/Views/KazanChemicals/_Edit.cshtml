@using AquaBusinessTrackingWebUI.Models
@using DTOLayer.Dtos.KazanChemicalsDtos.KazanChemicalsHeadDtos
@model ModalViewModel<KazanChemicalsFormDto>

<div class="modal fade" id="kazanChemicalsModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">@Model.ModalTitle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" action="/KazanChemicals/Edit">
                <div class="modal-body">

                    <input type="hidden" name="IsEdit" value="@Model.IsEdit.ToString().ToLower()" />

                    @if (Model.IsEdit)
                    {
                        <input type="hidden" asp-for="Entity.RecId" />
                    }

                    <input type="hidden" asp-for="Entity.DepartmentId" />
                    <input type="hidden" asp-for="Entity.AppUserId" />
                    <input type="hidden" asp-for="Entity.InsertDate" />



                    @if (Model.Entity.Detail != null)
                    {
                        <input type="hidden" asp-for="Entity.Detail.RecId" />
                        <input type="hidden" asp-for="Entity.Detail.KazanChemicalsHeadId" />
                    }

                    <!-- Genel Bilgiler -->
                    <h6 class="fw-bold text-muted mb-3">Kimyasal Bilgileri</h6>

                    <div class="row g-3 mb-4">

                        <div class="col-md-3">
                            <label class="form-label">Stok Kodu</label>
                            <input type="text"
                                   asp-for="Entity.InventoryCode"
                                   class="form-control" />
                        </div>

                        <div class="col-md-5">
                            <label class="form-label">Stok Adı</label>
                            <input type="text"
                                   asp-for="Entity.InventoryName"
                                   class="form-control" />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Gün</label>
                            <input type="text"
                                   asp-for="Entity.Day"
                                   class="form-control" />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Tarih</label>
                            <input type="date"
                                   asp-for="Entity.Date"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Vardiya</label>
                            <select asp-for="Entity.ShiftId"
                                    asp-items="ViewBag.Shifts"
                                    class="form-select">
                                <option value="">Vardiya Seçiniz</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Kayıt Eden</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <ion-icon name="person-outline"></ion-icon>
                                </span>
                                <input type="text"
                                       class="form-control"
                                       value="@ViewBag.AppUserName"
                                       disabled />
                            </div>
                        </div>

                    </div>

                    <hr />

                    <!-- Detay Bilgileri -->
                    <h6 class="fw-bold text-muted mb-3">Tüketim Bilgileri</h6>

                    <div class="row g-3">

                        <div class="col-md-4">
                            <label class="form-label">Gelen Miktar</label>
                            <input type="number"
                                   step="0.01"
                                   asp-for="Entity.Detail.Incoming"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Tüketim</label>
                            <input type="number"
                                   step="0.01"
                                   asp-for="Entity.Detail.Consumption"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Kalan</label>
                            <input type="number"
                                   step="0.01"
                                   asp-for="Entity.Detail.Remaining"
                                   class="form-control" />
                        </div>

                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-light"
                            data-bs-dismiss="modal">
                        İptal
                    </button>

                    <button type="submit"
                            class="btn btn-success px-4">
                        <ion-icon name="save-outline" class="me-1"></ion-icon>
                        @(Model.IsEdit ? "Güncelle" : "Kaydet")
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>