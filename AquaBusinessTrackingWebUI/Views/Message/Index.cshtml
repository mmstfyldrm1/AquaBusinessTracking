@using AquaBusinessTrackingWebUI.Models
@model List<UserListItemViewModel>
@{
    ViewData["Title"] = "Mesajlar";
    Layout = "~/Views/_UserLayout/Index.cshtml";
}

<style>
    .msg-wrapper {
        display: flex;
        height: 70vh;
        border: 1px solid #e8e8e6;
        border-radius: 12px;
        overflow: hidden;
    }

    .msg-user-list {
        width: 280px;
        border-right: 1px solid #e8e8e6;
        overflow-y: auto;
        background: #fafafa;
    }

    .msg-user-item {
        padding: .75rem 1rem;
        cursor: pointer;
        border-bottom: 1px solid #f0f0ee;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .msg-user-item:hover {
            background: #f0f0ee;
        }

        .msg-user-item.active {
            background: #E6F1FB;
        }

    .msg-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #378ADD;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 14px;
        flex-shrink: 0;
    }

    .msg-user-name {
        font-size: 13px;
        font-weight: 500;
    }

    .msg-chat-area {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .msg-chat-header {
        padding: .875rem 1.25rem;
        border-bottom: 1px solid #e8e8e6;
        font-weight: 500;
        font-size: 14px;
    }

    .msg-chat-body {
        flex: 1;
        overflow-y: auto;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .msg-bubble {
        max-width: 60%;
        padding: .5rem .875rem;
        border-radius: 14px;
        font-size: 13px;
        line-height: 1.4;
    }

    .msg-bubble-mine {
        align-self: flex-end;
        background: #378ADD;
        color: #fff;
        border-bottom-right-radius: 4px;
    }

    .msg-bubble-theirs {
        align-self: flex-start;
        background: #f0f0ee;
        color: #333;
        border-bottom-left-radius: 4px;
    }

    .msg-bubble-time {
        font-size: 10px;
        opacity: .7;
        margin-top: 3px;
        display: block;
    }

    .msg-chat-input {
        display: flex;
        gap: 8px;
        padding: .75rem 1rem;
        border-top: 1px solid #e8e8e6;
    }

        .msg-chat-input input {
            flex: 1;
            border: 1px solid #ddd;
            border-radius: 20px;
            padding: .5rem 1rem;
            font-size: 13px;
        }

        .msg-chat-input button {
            border: none;
            background: #378ADD;
            color: #fff;
            border-radius: 50%;
            width: 38px;
            height: 38px;
            flex-shrink: 0;
        }

    .msg-empty-state {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #999;
        font-size: 13px;
    }
</style>

<h6 class="mb-0 text-uppercase">Mesajlar</h6>
<hr />

<div class="msg-wrapper">
    <div class="msg-user-list" id="userList">
        @foreach (var user in Model)
        {
            <div class="msg-user-item" data-user-id="@user.Id" data-user-name="@user.Email">
                <div class="msg-avatar">@(user.Email.Length > 0 ? user.Email.Substring(0, 1).ToUpper() : "?")</div>
                <div class="msg-user-name">@user.Email</div>
            </div>
        }
    </div>

    <div class="msg-chat-area">
        <div id="chatEmptyState" class="msg-empty-state">
            Sohbet başlatmak için soldan bir kullanıcı seçin
        </div>

        <div id="chatActiveArea" style="display:none; flex-direction:column; height:100%;">
            <div class="msg-chat-header" id="chatHeaderName"></div>
            <div class="msg-chat-body" id="chatBody"></div>
            <div class="msg-chat-input">
                <input type="text" id="messageInput" placeholder="Mesaj yaz..." />
                <button id="sendButton" type="button">
                    <ion-icon name="send"></ion-icon>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        const jwtToken = "@ViewBag.JwtToken";
        const apiBaseUrl = "@ViewBag.ApiBaseUrl"; 
        const currentUserId = "@ViewBag.CurrentUserId";

        let selectedUserId = null;
        let selectedUserName = null;

        
        const hubBaseUrl = apiBaseUrl.replace(/\/api\/?$/, "");

        const connection = new signalR.HubConnectionBuilder()
            .withUrl(`${hubBaseUrl}/messageHub?access_token=${jwtToken}`)
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveMessage", function (message) {
            
            const isRelevant =
                (message.senderId == selectedUserId && message.receiverId == currentUserId) ||
                (message.senderId == currentUserId && message.receiverId == selectedUserId);

            if (isRelevant) {
                appendMessageToChat(message);
            }
        });

        connection.start().catch(function (err) {
            console.error("SignalR bağlantı hatası:", err);
        });

        
        document.querySelectorAll(".msg-user-item").forEach(function (item) {
            item.addEventListener("click", function () {
                document.querySelectorAll(".msg-user-item").forEach(i => i.classList.remove("active"));
                this.classList.add("active");

                selectedUserId = this.dataset.userId;
                selectedUserName = this.dataset.userName;

                document.getElementById("chatEmptyState").style.display = "none";
                document.getElementById("chatActiveArea").style.display = "flex";
                document.getElementById("chatHeaderName").innerText = selectedUserName;
                document.getElementById("chatBody").innerHTML = "";

                loadConversationHistory(selectedUserId);
                markMessagesAsRead(selectedUserId);
            });
        });

        
        document.getElementById("sendButton").addEventListener("click", sendMessage);
        document.getElementById("messageInput").addEventListener("keypress", function (e) {
            if (e.key === "Enter") sendMessage();
        });

        function sendMessage() {
            const input = document.getElementById("messageInput");
            const content = input.value.trim();
            if (!content || !selectedUserId) return;

            const dto = {
                senderId: parseInt(currentUserId),
                receiverId: parseInt(selectedUserId),
                content: content
            };

            connection.invoke("SendMessage", dto).catch(function (err) {
                console.error("Mesaj gönderme hatası:", err);
            });

            input.value = "";
        }

        
        function appendMessageToChat(message) {
            const chatBody = document.getElementById("chatBody");
            const isMine = message.senderId == currentUserId;

            const bubble = document.createElement("div");
            bubble.className = "msg-bubble " + (isMine ? "msg-bubble-mine" : "msg-bubble-theirs");

            const time = new Date(message.sentAt).toLocaleTimeString("tr-TR", { hour: "2-digit", minute: "2-digit" });

            bubble.innerHTML = `${escapeHtml(message.content)}<span class="msg-bubble-time">${time}</span>`;

            chatBody.appendChild(bubble);
            chatBody.scrollTop = chatBody.scrollHeight;
        }

        function escapeHtml(text) {
            const div = document.createElement("div");
            div.innerText = text;
            return div.innerHTML;
        }

       
        function loadConversationHistory(otherUserId) {
            fetch(`${apiBaseUrl}/Message/getall`, {
                headers: { "Authorization": "Bearer " + jwtToken }
            })
                .then(r => r.json())
                .then(allMessages => {
                    const conversation = allMessages.filter(m =>
                        (m.senderId == currentUserId && m.receiverId == otherUserId) ||
                        (m.senderId == otherUserId && m.receiverId == currentUserId)
                    ).sort((a, b) => new Date(a.sentAt) - new Date(b.sentAt));

                    conversation.forEach(appendMessageToChat);
                });
        }

            function markMessagesAsRead(otherUserId) {
        fetch(`${apiBaseUrl}/Message/markasread`, {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "Authorization": "Bearer " + jwtToken
            },
            body: JSON.stringify({
                senderId: parseInt(otherUserId),
                receiverId: parseInt(currentUserId)
            })
        }).catch(err => console.error("Okundu işaretleme hatası:", err));
            }
    </script>
}

