@using DTOLayer.Dtos.ElectricDtos.ElectricMotorTrackingDto
@model List<ElectricMotorDto>
@{
    ViewData["Title"] = "GetMotorList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
    int counter = 1;
}

<h6 class="mb-0 text-uppercase">Motor Takip Sistemi</h6>
<hr />

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table id="example2" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Fiş Tarihi</th>
                        <th>Sıra No</th>
                        <th>Marka</th>
                        <th>kW</th>
                        <th>Voltage</th>
                        <th>Açıklama</th>
                        <th>Kayıt Tarihi</th>
                        <th>Kayıt Eden</th>
                        <th>Vardiya</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@counter</td>
                            <td>@item.ReceiptDate.ToString("dd.MM.yyyy")</td>
                            <td>@item.ElectricMotorOrderNo</td>
                            <td>@item.ElectricMotorBrand</td>
                            <td>@item.kW</td>
                            <td>@item.Voltage</td>
                            <td>@item.Explanation</td>
                            <td>@item.InsertDate.ToString("dd.MM.yyyy")</td>
                            <td>@item.CreatedByName</td>
                            <td>@item.ShiftName</td>
                            <td class="text-center">

                                <button class="btn btn-sm btn-outline-warning px-2 py-1"
                                        onclick="openModal(@item.RecId)">
                                    <i class="bi bi-pencil-square fs-6"></i>
                                </button>

                            </td>

                            <td class="text-center">
                                <form method="post" asp-action="DeleteMotor" asp-route-id="@item.RecId" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Silinsin mi?');">
                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>
                                </form>
                            </td>

                        </tr>
                        counter++;
                    }


                </tbody>
                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Fiş Tarihi</th>
                        <th>Sıra No</th>
                        <th>Marka</th>
                        <th>kW</th>
                        <th>Voltage</th>
                        <th>Açıklama</th>
                        <th>Kayıt Tarihi</th>
                        <th>Kayıt Eden</th>
                        <th>Vardiya</th>
                    </tr>
                </tfoot>
            </table>
        </div>
        <button class="btn btn-primary shadow-sm" onclick="openModal()">
            <ion-icon name="add-circle-outline"></ion-icon>
            Yeni Motor Ekle
        </button>
    </div>
</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/ElectricMotorTracking/Edit/${id}`
            : `/ElectricMotorTracking/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('electricMotorModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/ElectricMotorTracking/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>
