@using DTOLayer.Dtos.ElectricDtos.ElectricMotorTrackingDto
@using AquaBusinessTrackingWebUI.Models
@model ModalViewModel<ElectricMotorDto>

<div class="modal fade" id="electricMotorModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">@Model.ModalTitle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" action="/ElectricMotorTracking/Edit">
                <div class="modal-body">
                    <div class="row g-3">

                        @if (Model.IsEdit)
                        {
                            <input type="hidden" asp-for="Entity.RecId" />
                        }
                        <div class="col-md-6">
                            <label class="form-label">Fiş Tarihi</label>
                            <input type="date" asp-for="Entity.ReceiptDate" class="form-control" placeholder="" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Motor Sipariş No</label>
                            <input type="text" asp-for="Entity.ElectricMotorOrderNo" class="form-control" placeholder="Örn: EM-001" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Marka</label>
                            <input type="text" asp-for="Entity.ElectricMotorBrand" class="form-control" placeholder="Örn: Siemens" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Güç (kW)</label>
                            <div class="input-group">
                                <input type="number" step="0.01" asp-for="Entity.kW" class="form-control" />
                                <span class="input-group-text">kW</span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Voltaj</label>
                            <div class="input-group">
                                <input type="number" asp-for="Entity.Voltage" class="form-control" />
                                <span class="input-group-text">V</span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Açıklma</label>
                            <div class="input-group">
                                <input type="text" asp-for="Entity.Explanation" class="form-control" />
                                <span class="input-group-text">V</span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Vardiya</label>
                            <select asp-for="Entity.ShiftId" asp-items="ViewBag.Shifts" class="form-select">
                                <option value="">Vardiya Seçiniz</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Kayıt Eden</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <ion-icon name="person-outline"></ion-icon>
                                </span>
                                <input type="text" class="form-control" value="@ViewBag.AppUserName" disabled />
                            </div>
                        </div>

                        <input type="hidden" asp-for="Entity.DepartmentId" />
                        <input type="hidden" asp-for="Entity.AppUserId" />
                        <input type="hidden" asp-for="Entity.InsertDate" />

                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-success px-4">
                        <ion-icon name="save-outline" class="me-1"></ion-icon>
                        @(Model.IsEdit ? "Güncelle" : "Kaydet")
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>