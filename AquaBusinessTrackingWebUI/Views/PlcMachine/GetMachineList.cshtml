
@{
    ViewData["Title"] = "GetMachineList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
}

<h6 class="mb-0 text-uppercase">PLC Makine Takip Sistemi</h6>
<hr />

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table id="example2" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Makine Adı</th>
                        <th>IP Adresi</th>
                        <th>Rack</th>
                        <th>Slot</th>
                        <th>CPU Tipi</th>
                        <th>Durum</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </thead>

                <tbody>
                    @{
                        int counter = 1;
                    }

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@counter</td>
                            <td>@item.Name</td>
                            <td>@item.IpAddress</td>
                            <td>@item.Rack</td>
                            <td>@item.Slot</td>
                            <td>@item.CpuType</td>

                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Pasif</span>
                                }
                            </td>

                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning px-2 py-1"
                                        onclick="openModal(@item.RecId)">
                                    <i class="bi bi-pencil-square fs-6"></i>
                                </button>
                            </td>

                            <td class="text-center">
                                <form method="post"
                                      asp-action="Delete"
                                      asp-route-id="@item.RecId"
                                      style="display:inline;">
                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Silinsin mi?');">
                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>
                                </form>
                            </td>
                        </tr>

                        counter++;
                    }
                </tbody>

                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Makine Adı</th>
                        <th>IP Adresi</th>
                        <th>Rack</th>
                        <th>Slot</th>
                        <th>CPU Tipi</th>
                        <th>Durum</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </tfoot>
            </table>
        </div>

        <button class="btn btn-primary shadow-sm" onclick="openModal()">
            <ion-icon name="add-circle-outline"></ion-icon>
            Yeni Makine Ekle
        </button>
    </div>
</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/PlcMachine/Edit/${id}`
            : `/PlcMachine/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('PlcMachineModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/PlcMachine/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>

