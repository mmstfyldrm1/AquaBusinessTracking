@using DTOLayer.Dtos.MassWasteDtos.MassWasteBalanceDtos

@{
    ViewData["Title"] = "GetMassWasteBalanceList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
    int counter = 1;
}

@model List<MassWasteBalanceDto>

<h6 class="mb-0 text-uppercase">Kütle Denge Firma BZ</h6>
<hr />

<div class="card">
    <div class="card-body">
        <div class="table-responsive">

            <table id="example2" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Ay</th>
                        <th>Yıl</th>
                        <th>Atık Kodu</th>

                        <th>Önceki Ay Devri</th>
                        <th>Üretimde Kullanım</th>
                        <th>Sonraki Ay Devri</th>

                        <th>Kayıt Eden</th>
                        <th>Vardiya</th>

                        <th>Kayıt Tarihi</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@counter</td>

                            <td>@item.Month</td>
                            <td>@item.Year</td>

                            <td>@item.WasteCode</td>

                            <td>@item.PreviousMonthCarryover</td>
                            <td>@item.UsedInProduction</td>
                            <td>@item.NextMonthCarryover</td>

                            <td>@item.CreatedByName</td>
                            <td>@item.ShiftName</td>

                            <td>
                                @(item.InsertDate.HasValue
                                                            ? item.InsertDate.Value.ToString("dd.MM.yyyy HH:mm")
                                                            : "-")
                        </td>

                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning px-2 py-1"
                                        onclick="openModal(@item.RecId)">
                                    <i class="bi bi-pencil-square fs-6"></i>
                                </button>
                            </td>

                            <td class="text-center">
                                <form method="post"
                                      asp-action="Delete"
                                      asp-route-id="@item.RecId"
                                      style="display:inline;">
                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Silinsin mi?');">
                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>
                                </form>
                            </td>
                        </tr>

                                        counter++;
                    }
                </tbody>

                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Ay</th>
                        <th>Yıl</th>
                        <th>Atık Kodu</th>

                        <th>Önceki Ay Devri</th>
                        <th>Üretimde Kullanım</th>
                        <th>Sonraki Ay Devri</th>

                        <th>Kayıt Eden</th>
                        <th>Vardiya</th>

                        <th>Kayıt Tarihi</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </tfoot>
            </table>

        </div>

        <button class="btn btn-primary shadow-sm" onclick="openModal()">
            <ion-icon name="add-circle-outline"></ion-icon>
            Yeni Kayıt Ekle
        </button>

    </div>
</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/MassWasteBalance/Edit/${id}`
            : `/MassWasteBalance/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('massWasteBalanceModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/MassWasteBalance/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>

