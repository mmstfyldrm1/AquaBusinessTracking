@using AquaBusinessTrackingWebUI.Models
@using DTOLayer.Dtos.MassWasteDtos.MassWasteBalanceDtos
@model ModalViewModel<MassWasteBalanceDto>

<div class="modal fade" id="massWasteBalanceModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">@Model.ModalTitle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" action="/MassWasteBalance/Edit">
                <div class="modal-body">

                    <input type="hidden" name="IsEdit" value="@Model.IsEdit.ToString().ToLower()" />

                    @if (Model.IsEdit)
                    {
                        <input type="hidden" asp-for="Entity.RecId" />
                    }

                    <div class="row g-3">

                        <!-- AY -->
                        <div class="col-md-4">
                            <label class="form-label">Ay</label>
                            <input type="number" asp-for="Entity.Month"
                                   class="form-control" min="1" max="12" />
                        </div>

                        <!-- YIL -->
                        <div class="col-md-4">
                            <label class="form-label">Yıl</label>
                            <input type="number" asp-for="Entity.Year"
                                   class="form-control" />
                        </div>

                        <!-- ATIK KODU -->
                        <div class="col-md-4">
                            <label class="form-label">Atık Kodu</label>
                            <input type="text" asp-for="Entity.WasteCode"
                                   class="form-control" />
                        </div>

                        <!-- ÖNCEKİ AY DEVİR -->
                        <div class="col-md-4">
                            <label class="form-label">Önceki Ay Devri</label>
                            <input type="number" step="0.01"
                                   asp-for="Entity.PreviousMonthCarryover"
                                   class="form-control" />
                        </div>

                        <!-- ÜRETİMDE KULLANIM -->
                        <div class="col-md-4">
                            <label class="form-label">Üretimde Kullanım</label>
                            <input type="number" step="0.01"
                                   asp-for="Entity.UsedInProduction"
                                   class="form-control" />
                        </div>

                        <!-- SONRAKİ AY DEVİR -->
                        <div class="col-md-4">
                            <label class="form-label">Sonraki Ay Devri</label>
                            <input type="number" step="0.01"
                                   asp-for="Entity.NextMonthCarryover"
                                   class="form-control" />
                        </div>

                        <!-- VARDİYA -->
                        <div class="col-md-4">
                            <label class="form-label">Vardiya</label>
                            <select asp-for="Entity.ShiftId"
                                    asp-items="ViewBag.Shifts"
                                    class="form-select">
                                <option value="">Seçiniz</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Durum</label>
                            <select asp-for="Entity.InUse" class="form-select">
                                <option value="1">Aktif</option>
                                <option value="0">Pasif</option>
                            </select>
                        </div>

                        <!-- KULLANICI -->
                        <div class="col-md-4">
                            <label class="form-label">Kayıt Eden</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <ion-icon name="person-outline"></ion-icon>
                                </span>
                                <input type="text"
                                       class="form-control"
                                       value="@ViewBag.AppUserName"
                                       disabled />
                            </div>
                        </div>

                        <!-- HIDDEN FIELDS -->
                        <input type="hidden" asp-for="Entity.AppUserId" />
                        <input type="hidden" asp-for="Entity.InsertDate" />
                        <input type="hidden" asp-for="Entity.UpdateDate" />
                        <input type="hidden" asp-for="Entity.DeleteDate" />
                        <input type="hidden" asp-for="Entity.InUse" />
                        <input type="hidden" asp-for="Entity.DeletedBy" />
                        <input type="hidden" asp-for="Entity.UpdatedBy" />

                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                        İptal
                    </button>

                    <button type="submit" class="btn btn-success px-4">
                        <ion-icon name="save-outline" class="me-1"></ion-icon>
                        @(Model.IsEdit ? "Güncelle" : "Kaydet")
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>