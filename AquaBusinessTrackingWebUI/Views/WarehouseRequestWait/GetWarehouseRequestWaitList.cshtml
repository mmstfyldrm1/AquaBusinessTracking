@using DTOLayer.Dtos.WarehouseRequestWaitDtos

@{
    ViewData["Title"] = "GetWarehouseRequestWaitList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
}

@model IEnumerable<WarehouseRequestWaitDto>

<h6 class="mb-0 text-uppercase">Depo Talep Bekleyen</h6>
<hr />

<div class="card">

    <div class="card-body">

        <div class="table-responsive">

            <table id="example2"
                   class="table table-striped table-bordered">

                <thead>

                    <tr>

                        <th>#</th>
                        <th>İrsaliye No</th>
                        <th>Fatura No</th>
                        <th>Cari Hesap</th>
                        <th>Stok Kodu</th>
                        <th>Stok Adı</th>
                        <th>Stok Grubu</th>
                        <th>Miktar</th>
                        <th>Birim</th>
                        <th>Depo Giriş</th>
                        <th>İade Tarih</th>
                        <th>Bekleme Süresi</th>
                        <th>Kullanıcı</th>
                        <th>Vardiya</th>
                        <th>Aktif</th>
                        <th>Kayıt Tarihi</th>
                        <th>Güncelle</th>
                        <th>Sil</th>

                    </tr>

                </thead>

                <tbody>

                    @{
                        int counter = 1;
                    }

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@counter</td>

                            <td>
                                @(item.WaybillNo ?? "-")
                            </td>

                            <td>
                                @(item.WaybillInvoiceNo ?? "-")
                            </td>

                            <td>
                                @(item.IncomingCurrentAccountName ?? "-")
                            </td>

                            <td>
                                @(item.SentezInventoryCode ?? "-")
                            </td>

                            <td>
                                @(item.SentezInventoryName ?? "-")
                            </td>

                            <td>
                                @(item.SentezInventoryGroup ?? "-")
                            </td>

                            <td>
                                @item.Quanity.ToString("N2")
                            </td>

                            <td>
                                @(item.Unit ?? "-")
                            </td>

                            <td>
                                @item.WarehouseEntryDate.ToString(@"hh\:mm")
                            </td>

                            <td>
                                @item.ReturnDate.ToString(@"hh\:mm")
                            </td>

                            <td>
                                @(item.WaitingTime ?? "-")
                            </td>

                            <td>
                                @item.CreatedByName
                            </td>

                            <td>
                                @(item.ShiftName ?? "-")
                            </td>

                            <td>

                                @if (item.InUse == 1)
                                {
                                    <span class="badge bg-success">
                                        Aktif
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Pasif
                                    </span>
                                }

                            </td>

                            <td>
                                @(item.InsertDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                            </td>

                            <td class="text-center">

                                <button class="btn btn-sm btn-outline-warning px-2 py-1"
                                        onclick="openModal(@item.RecId)">

                                    <i class="bi bi-pencil-square fs-6"></i>

                                </button>

                            </td>

                            <td class="text-center">

                                <form method="post"
                                      asp-action="Delete"
                                      asp-route-id="@item.RecId"
                                      style="display:inline;">

                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Silinsin mi?');">

                                        <ion-icon name="trash-outline"></ion-icon>

                                    </button>

                                </form>

                            </td>

                        </tr>

                        counter++;
                    }

                </tbody>

                <tfoot>

                    <tr>

                        <th>#</th>
                        <th>İrsaliye No</th>
                        <th>Fatura No</th>
                        <th>Cari Hesap</th>
                        <th>Stok Kodu</th>
                        <th>Stok Adı</th>
                        <th>Stok Grubu</th>
                        <th>Miktar</th>
                        <th>Birim</th>
                        <th>Depo Giriş</th>
                        <th>İade Tarih</th>
                        <th>Bekleme Süresi</th>
                        <th>Kullanıcı</th>
                        <th>Vardiya</th>
                        <th>Aktif</th>
                        <th>Kayıt Tarihi</th>
                        <th>Güncelle</th>
                        <th>Sil</th>

                    </tr>

                </tfoot>

            </table>

        </div>

        <button class="btn btn-primary shadow-sm"
                onclick="openModal()">

            <ion-icon name="add-circle-outline"></ion-icon>

            Yeni Kayıt Ekle

        </button>

    </div>

</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/WarehouseRequestWait/Edit/${id}`
            : `/WarehouseRequestWait/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('warehouseRequestWaitModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/WarehouseRequestWait/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>
