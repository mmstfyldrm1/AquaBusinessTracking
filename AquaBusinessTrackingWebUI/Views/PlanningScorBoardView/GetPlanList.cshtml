@using DTOLayer.Dtos.PlanningScorBoardViewDtos

@{
    ViewData["Title"] = "GetPlanList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
    int counter = 0;
}
@model List<PlanningScorBoardViewDto>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">

            <table id="example2" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Plan No</th>
                        <th>Plan Tarihi</th>
                        <th>Plan</th>
                        <th>Kayıt Tarihi</th>
                        <th>Kayıt Eden</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                        <th>Detay</th>

                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                           
                            <td>@counter</td>

                            <td>@item.PlanNo</td>

                            <td>
                                @(item.ReceiptDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                            </td>

                            <td>@item.UploadPdf</td>

                          

                            <td>
                                @(item.InsertDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                            </td>

                            <td>@item.CreatedByName</td>

                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning"
                                        onclick="openModal(@item.RecId)">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                            </td>

                            <td class="text-center">
                                <form method="post"
                                      asp-action="Delete"
                                      asp-route-id="@item.RecId"
                                      onsubmit="return confirm('Silinsin mi?');">

                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>

                                </form>
                            </td>

                            <td class="text-center">
                                <a href="/PlanningScorBoardView/ViewPlan/@item.RecId"
                                   class="btn btn-sm btn-outline-info"
                                   title="Detay Gör">
                                    <ion-icon name="eye-outline"></ion-icon>
                                </a>
                            </td>
                        </tr>

                        counter++;
                    }
                </tbody>

                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Plan No</th>
                        <th>Plan Tarihi</th>
                        <th>Plan</th>
                        <th>Kayıt Tarihi</th>
                        <th>Kayıt Eden</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                        <th>Detay</th>
                    </tr>
                </tfoot>

            </table>

        </div>

        <button class="btn btn-primary shadow-sm" onclick="openModal()">
            <ion-icon name="add-circle-outline"></ion-icon>
            Yeni Kayıt Ekle
        </button>

    </div>
</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/PlanningScorBoardView/Edit/${id}`
            : `/PlanningScorBoardView/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('planningScoreModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/PlanningScorBoardView/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>
