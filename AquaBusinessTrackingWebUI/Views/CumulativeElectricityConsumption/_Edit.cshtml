@using AquaBusinessTrackingWebUI.Models
@using DTOLayer.Dtos.ElectricDtos.CumulativeElectricityConsumptionDtos
@model ModalViewModel<CumulativeElectricityConsumptionDto>

<div class="modal fade" id="cumulativeElectricityConsumptionModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">@Model.ModalTitle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" action="/ElectricConsumption/Edit">
                <div class="modal-body">
                    <div class="row g-3">

                        @if (Model.IsEdit)
                        {
                            <input type="hidden" asp-for="Entity.RecId" />
                        }

                        <div class="col-md-3">
                            <label class="form-label">Yıl</label>
                            <input type="number"
                                   asp-for="Entity.Year"
                                   class="form-control" />
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Ay</label>
                            <input type="number"
                                   min="1"
                                   max="12"
                                   asp-for="Entity.Month"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Lokasyon</label>
                            <select asp-for="Entity.ElectricMeterLocationId"
                                    asp-items="ViewBag.Location"
                                    class="form-select">
                                <option value="">Lokasyon Seçiniz</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Tüketim</label>
                            <div class="input-group">
                                <input type="number"
                                       step="0.01"
                                       asp-for="Entity.Consumption"
                                       class="form-control" />
                                <span class="input-group-text">kWh</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Tarih</label>
                            <input type="date"
                                   asp-for="Entity.ReceiptDate"
                                   class="form-control" />
                        </div>

                        <!-- VARDIYA -->
                        <div class="col-md-6">
                            <label class="form-label">Vardiya</label>

                            <select asp-for="Entity.ShiftId"
                                    asp-items="ViewBag.Shifts"
                                    class="form-select">

                                <option value="">Vardiya Seçiniz</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Kayıt Eden</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <ion-icon name="person-outline"></ion-icon>
                                </span>
                                <input type="text"
                                       class="form-control"
                                       value="@ViewBag.AppUserName"
                                       disabled />
                            </div>
                        </div>

                        

                        <input type="hidden" asp-for="Entity.InsertDate" />
                        <input type="hidden" asp-for="Entity.UpdateDate" />
                        <input type="hidden" asp-for="Entity.DeleteDate" />
                        <input type="hidden" asp-for="Entity.DepartmentId" />

                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-light"
                            data-bs-dismiss="modal">
                        İptal
                    </button>

                    <button type="submit"
                            class="btn btn-success px-4">
                        <ion-icon name="save-outline" class="me-1"></ion-icon>
                        @(Model.IsEdit ? "Güncelle" : "Kaydet")
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>