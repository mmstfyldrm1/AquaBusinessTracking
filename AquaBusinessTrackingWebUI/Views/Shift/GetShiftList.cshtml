@using DTOLayer.Dtos.ShiftDtos
@model List<ShiftDto>

@{
    ViewData["Title"] = "GetShiftList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
    int counter = 1;
}

<h6 class="mb-0 text-uppercase">Vardiya Listesi</h6>
<hr />

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table id="example2" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Vardiya Adı</th>
                        <th>Vardiya Kodu</th>
                        <th>Başlangıç Saati</th>
                        <th>Bitiş Saati</th>
                        <th>Kayıt Tarihi</th>
                        <th>Güncellenme Tarihi</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@counter</td>

                            <td>@item.ShiftName</td>
                            <td>@item.ShiftCode</td>
                            <td>
                                @(item.ShiftStartHours.HasValue? item.ShiftStartHours.Value.ToString(@"hh\:mm")    : "-")
                            </td>
                            <td>
                                @(item.ShiftEndHours.HasValue? item.ShiftEndHours.Value.ToString(@"hh\:mm")   : "-")
                            </td>
                            <td>
                                @item.InsertDate.ToString()
                            </td>
                            <td>
                                @(item.UpdateDate.HasValue? item.UpdateDate.Value.ToString("dd.MM.yyyy HH:mm")  : "-")
                                                           
                                                          
                        </td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning px-2 py-1"
                                        onclick="openModal(@item.RecId)">
                                    <i class="bi bi-pencil-square fs-6"></i>
                                </button>
                            </td>

                            <td class="text-center">
                                <form method="post"
                                      asp-action="DeleteShift"
                                      asp-route-id="@item.RecId"
                                      style="display:inline;">

                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Silinsin mi?');">

                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>
                                </form>
                            </td>
                        </tr>

                        counter++;


                    }
                </tbody>

                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Vardiya Adı</th>
                        <th>Vardiya Kodu</th>
                        <th>Başlangıç Saati</th>
                        <th>Bitiş Saati</th>
                        <th>Kayıt Tarihi</th>
                        <th>GÜncelleme Tarihi</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </tfoot>

            </table>
        </div>

        <button class="btn btn-primary shadow-sm" onclick="openModal()">
            <ion-icon name="add-circle-outline"></ion-icon>
            Yeni Vardiya Ekle
        </button>
    </div>
</div>
<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/Shift/Edit/${id}`
            : `/Shift/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('shiftModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/Shift/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>


