@using DTOLayer.Dtos.AuthDtos
@{
    Layout = null;
}

@model RegisterDto

<!doctype html>
<html lang="en" class="light-theme">

<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- loader-->
    <link href="~/ltr/assets/css/pace.min.css" rel="stylesheet" />
    <script src="~/ltr/assets/js/pace.min.js"></script>

    <!--plugins-->
    <link href="~/ltr/assets/plugins/perfect-scrollbar/css/perfect-scrollbar.css" rel="stylesheet" />
    <!-- CSS Files -->
    <link href="~/ltr/assets/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/ltr/assets/css/bootstrap-extended.css" rel="stylesheet">
    <link href="~/ltr/assets/css/style.css" rel="stylesheet">
    <link href="~/ltr/assets/css/icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500&display=swap" rel="stylesheet">

    <title>Aquakraft - Kayıt Ol</title>

    <style>
        body {
            /* Netleştirilmiş fabrika görselini arka plana ekliyoruz */
            background-image: url('/img/indir.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
            position: relative;
            min-height: 100vh;
            font-family: 'Roboto', sans-serif;
        }

            /* Arka planı biraz karartarak formun öne çıkmasını sağlar */
            body::before {
                content: "";
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0, 0, 0, 0.55);
                z-index: -1;
            }

        .wrapper {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Cam efekti (Glassmorphism) ve modern kart tasarımı */
        .card {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(10px);
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        .form-control, .form-select {
            background: rgba(255, 255, 255, 0.8);
            border: 1px solid #ced4da;
        }

        footer {
            color: #ffffff;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
        }

        .social-login-footer a {
            color: #ffffff;
            transition: 0.3s;
        }

            .social-login-footer a:hover {
                color: #0d6efd;
                transform: translateY(-3px);
            }
    </style>
</head>

<body>

    <!--start wrapper-->
    <div class="wrapper">
        <div class="container my-auto">
            <div class="row">
                <div class="col-xl-4 col-lg-5 col-md-7 mx-auto mt-5 mb-5">
                    <div class="card shadow-lg">
                        <div class="card-body p-4">
                            <div class="text-center mb-4">
                                <h4 class="fw-bold text-uppercase" style="letter-spacing: 1px;">AQUAKRAFT KAĞIT</h4>
                                <p class="text-muted">Yeni Hesap Oluştur</p>
                            </div>
                            <form method="post" asp-action="Register" asp-controller="Auth" class="form-body row g-3">
                                @Html.AntiForgeryToken()

                                <div class="col-12 col-lg-6">
                                    <label asp-for="Name" class="form-label">İsim</label>
                                    <input asp-for="Name" type="text" class="form-control" id="inputName" placeholder="Adınız">
                                </div>
                                <div class="col-12 col-lg-6">
                                    <label asp-for="SurName" class="form-label">Soyisim</label>
                                    <input asp-for="SurName" type="text" class="form-control" id="inputSurname" placeholder="Soyadınız">
                                </div>

                                <div class="col-12">
                                    <label asp-for="Email" class="form-label">Mail Adresiniz</label>
                                    <input asp-for="Email" type="email" class="form-control" id="inputEmail" placeholder="ornek@aquakraft.com">
                                </div>

                                <div class="col-12">
                                    <label asp-for="Phone" class="form-label">Telefon Numaranız</label>
                                    <input asp-for="Phone" type="text" class="form-control" id="inputPhone" placeholder="05xx xxx xx xx">
                                </div>

                                <div class="col-12">
                                    <label asp-for="Password" class="form-label">Şifre</label>
                                    <input asp-for="Password" type="password" class="form-control" id="inputPassword" placeholder="********">
                                </div>

                                <div class="col-12">
                                    <label asp-for="DepartmentId" class="form-label">Departman</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-primary text-white">
                                            <i class="bi bi-briefcase"></i>
                                        </span>
                                        <select name="DepartmentId"
                                                asp-items="ViewBag.Department"
                                                class="form-select"
                                                required>
                                            <option value="">Departman Seçiniz</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" value="" id="flexCheckChecked" checked required>
                                        <label class="form-check-label" for="flexCheckChecked">
                                            Kullanım Koşullarını Kabul Ediyorum
                                        </label>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-primary btn-lg radius-10">Kayıt Ol</button>
                                    </div>
                                </div>

                                <div class="col-12 text-center">
                                    <p class="mb-0">Hesabınız var mı? <a href="/Auth/Login" class="fw-bold">Giriş Yap</a></p>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <footer class="py-4 mt-auto">
            <div class="container text-center">
                <div class="d-flex align-items-center gap-4 fs-4 justify-content-center social-login-footer mb-3">
                    <a href="javascript:;"><i class="bi bi-linkedin"></i></a>
                    <a href="javascript:;"><i class="bi bi-github"></i></a>
                    <a href="javascript:;"><i class="bi bi-facebook"></i></a>
                </div>
                <p class="mb-0 small">Copyright © 2026 Aquakraft Kağıt. Tüm Hakları Saklıdır.</p>
            </div>
        </footer>
    </div>
    <!--end wrapper-->

    <script src="~/ltr/assets/js/bootstrap.bundle.min.js"></script>
</body>
</html>