@using DTOLayer.Dtos.IncomingGoodsTrackingDtos

@{
    ViewData["Title"] = "GetIncomingGoodsTrackingList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
    int counter = 0;
}

@model List<IncomingGoodsTrackingDto>
<h6 class="mb-0 text-uppercase">Kantar Takip Sistemi</h6>
<hr />

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table id="example2" class="table table-striped table-bordered align-middle">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tarih</th>
                        <th>Saat</th>
                        <th>İrsaliye No</th>
                        <th>Fiş No</th>
                        <th>Cari</th>
                        <th>Malzeme</th>
                        <th>Plaka</th>
                        <th>Operatör</th>
                        <th>Birim</th>
                        <th>İrsaliye Miktarı</th>
                        <th>Dolu Ağırlık</th>
                        <th>Boş Ağırlık</th>
                        <th>Net Ağırlık</th>
                        <th>Vardiya</th>
                        <th>Açıklama</th>
                        <th>Kayıt Tarihi</th>
                        <th>Kayıt Eden</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@counter</td>

                            <td>@item.ReceiptDate.ToString("dd.MM.yyyy")</td>
                            <td>@item.ScaleHours.ToString(@"hh\:mm")</td>

                            <td>@item.WaybillNo</td>
                            <td>@item.ReceiptNo</td>

                            <td>@item.CurrentAccountName</td>
                            <td>@item.InventoryName</td>
                            <td>@item.Plate</td>
                            <td>@item.Operator</td>
                            <td>@item.Unit</td>

                            <td>@item.WaybillQuantity</td>
                            <td>@item.FilledQuantity</td>
                            <td>@item.EmptyQuantity</td>
                            <td>@item.NetQuantity</td>

                            <td>@item.ShiftName</td>
                            <td>@item.Description</td>

                            <td>@item.InsertDate?.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@item.CreatedByName</td>

                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning"
                                        onclick="openModal(@item.RecId)">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                            </td>

                            <td class="text-center">
                                <form method="post"
                                      asp-action="Delete"
                                      asp-route-id="@item.RecId"
                                      style="display:inline;">
                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Silinsin mi?');">
                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>
                                </form>
                            </td>
                        </tr>

                        counter++;
                    }
                </tbody>

                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Tarih</th>
                        <th>Saat</th>
                        <th>İrsaliye No</th>
                        <th>Fiş No</th>
                        <th>Cari</th>
                        <th>Malzeme</th>
                        <th>Plaka</th>
                        <th>Operatör</th>
                        <th>Birim</th>
                        <th>İrsaliye Miktarı</th>
                        <th>Dolu Ağırlık</th>
                        <th>Boş Ağırlık</th>
                        <th>Net Ağırlık</th>
                        <th>Vardiya</th>
                        <th>Açıklama</th>
                        <th>Kayıt Tarihi</th>
                        <th>Kayıt Eden</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </tfoot>
            </table>
        </div>

        <button class="btn btn-primary shadow-sm mt-3" onclick="openModal()">
            <ion-icon name="add-circle-outline"></ion-icon>
            Yeni Kayıt Ekle
        </button>
    </div>
</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/IncomingGoodsTracking/Edit/${id}`
            : `/IncomingGoodsTracking/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('incomingGoodsTrackingModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/IncomingGoodsTracking/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>