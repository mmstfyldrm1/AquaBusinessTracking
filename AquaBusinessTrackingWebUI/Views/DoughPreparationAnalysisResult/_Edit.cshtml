@using DTOLayer.Dtos.DoughPreparationDtos.DoughPreparationDetailDtos
@using AquaBusinessTrackingWebUI.Models

@model ModalViewModel<DoughPreparationAnalysisResultsDto>

<div class="modal fade" id="doughPreparationResultModal" tabindex="-1" aria-hidden="true">

    <div class="modal-dialog modal-xl modal-dialog-centered">

        <div class="modal-content border-0 shadow-lg">

            <!-- Modal Header -->
            <div class="modal-header bg-light">

                <div>
                    <h5 class="modal-title fw-bold mb-1">
                        @Model.ModalTitle
                    </h5>

                    <small class="text-muted">
                        Laboratuvar analiz bilgilerini giriniz
                    </small>
                </div>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <!-- Form -->
            <form method="post" action="/DoughPreparationAnalysisResults/Edit">

                <div class="modal-body">

                    <div class="row g-4">

                        @if (Model.IsEdit)
                        {
                            <input type="hidden" asp-for="Entity.RecId" />
                        }
                        <div class="col-md-4">

                            <label class="form-label fw-semibold">
                                Tarih
                            </label>

                            <input type="date"
                                   asp-for="Entity.ReceiptDate"
                                   class="form-control shadow-sm"
                                   placeholder="Örn: 120" />

                        </div>

                        <!-- Numune Alım Süresi -->
                        <div class="col-md-4">

                            <label class="form-label fw-semibold">
                                Numune Alım Süresi
                            </label>

                            <div class="input-group">

                                <input type="number"
                                       asp-for="Entity.SampleCollectionTime"
                                       class="form-control shadow-sm"
                                       placeholder="Örn: 15" />

                                <span class="input-group-text">
                                    dk
                                </span>

                            </div>

                        </div>

                        <!-- Sonuç Teslim Süresi -->
                        <div class="col-md-4">

                            <label class="form-label fw-semibold">
                                Sonuç Teslim Süresi
                            </label>

                            <div class="input-group">

                                <input type="number"
                                       asp-for="Entity.SampleResultDeliveryTime"
                                       class="form-control shadow-sm"
                                       placeholder="Örn: 45" />

                                <span class="input-group-text">
                                    dk
                                </span>

                            </div>

                        </div>

                        <!-- SR -->
                        <div class="col-md-4">

                            <label class="form-label fw-semibold">
                                SR
                            </label>

                            <input type="number"
                                   asp-for="Entity.SR"
                                   class="form-control shadow-sm"
                                   placeholder="Örn: 120" />

                        </div>

                        <!-- Numune Alınan Lokasyon -->
                        <div class="col-md-6">

                            <label class="form-label fw-semibold">
                                Numune Alınan Lokasyon
                            </label>

                            <div class="input-group">

                                <span class="input-group-text">
                                    <ion-icon name="location-outline"></ion-icon>
                                </span>

                                <input type="text"
                                       asp-for="Entity.SampleTakenLocation"
                                       class="form-control shadow-sm"
                                       placeholder="Örn: Hamur Hazırlama Tankı" />

                            </div>

                        </div>

                        <!-- KM -->
                        <div class="col-md-3">

                            <label class="form-label fw-semibold">
                                KM
                            </label>

                            <input type="number"
                                   step="0.01"
                                   asp-for="Entity.KM"
                                   class="form-control shadow-sm"
                                   placeholder="Örn: 7.25" />

                        </div>

                        <!-- pH -->
                        <div class="col-md-3">

                            <label class="form-label fw-semibold">
                                pH
                            </label>

                            <input type="number"
                                   step="0.01"
                                   asp-for="Entity.pH"
                                   class="form-control shadow-sm"
                                   placeholder="Örn: 6.80" />

                        </div>

                        <!-- Kuru Madde -->
                        <div class="col-md-4">

                            <label class="form-label fw-semibold">
                                Kuru Madde
                            </label>

                            <div class="input-group">

                                <input type="number"
                                       asp-for="Entity.DryMatter"
                                       class="form-control shadow-sm"
                                       placeholder="Örn: 32" />

                                <span class="input-group-text">
                                    %
                                </span>

                            </div>

                        </div>

                        <!-- İletkenlik -->
                        <div class="col-md-4">

                            <label class="form-label fw-semibold">
                                İletkenlik
                            </label>

                            <input type="number"
                                   asp-for="Entity.Conductivity"
                                   class="form-control shadow-sm"
                                   placeholder="Örn: 1500" />

                        </div>

                        <!-- CaCO3 -->
                        <div class="col-md-4">

                            <label class="form-label fw-semibold">
                                CaCO3
                            </label>

                            <div class="input-group">

                                <input type="number"
                                       asp-for="Entity.CaCO3"
                                       class="form-control shadow-sm"
                                       placeholder="Örn: 18" />

                                <span class="input-group-text">
                                    %
                                </span>

                            </div>

                        </div>

                        <!-- Dolgu -->
                        <div class="col-md-6">

                            <label class="form-label fw-semibold">
                                Dolgu
                            </label>

                            <div class="input-group">

                                <input type="number"
                                       step="0.01"
                                       asp-for="Entity.Filling"
                                       class="form-control shadow-sm"
                                       placeholder="Örn: 14.50" />

                                <span class="input-group-text">
                                    %
                                </span>

                            </div>

                        </div>

                        <!-- Bulanıklık -->
                        <div class="col-md-6">

                            <label class="form-label fw-semibold">
                                Bulanıklık
                            </label>

                            <input type="number"
                                   asp-for="Entity.Blur"
                                   class="form-control shadow-sm"
                                   placeholder="Örn: 5" />

                        </div>

                        <!-- Açıklama -->
                        <div class="col-12">

                            <label class="form-label fw-semibold">
                                Açıklama
                            </label>

                            <textarea asp-for="Entity.Explanation"
                                      class="form-control shadow-sm"
                                      rows="3"
                                      placeholder="Analiz hakkında açıklama giriniz..."></textarea>

                        </div>

                        <!-- Vardiya -->
                        <div class="col-md-6">

                            <label class="form-label fw-semibold">
                                Vardiya
                            </label>

                            <select asp-for="Entity.ShiftId"
                                    asp-items="ViewBag.Shifts"
                                    class="form-select shadow-sm">

                                <option value="">
                                    Vardiya Seçiniz
                                </option>

                            </select>

                        </div>

                        <!-- Kayıt Eden -->
                        <div class="col-md-6">

                            <label class="form-label fw-semibold">
                                Kayıt Eden
                            </label>

                            <div class="input-group">

                                <span class="input-group-text">
                                    <ion-icon name="person-outline"></ion-icon>
                                </span>

                                <input type="text"
                                       class="form-control shadow-sm"
                                       value="@ViewBag.AppUserName"
                                       disabled />

                            </div>

                        </div>

                        <!-- Hidden Alanlar -->
                        <input type="hidden" asp-for="Entity.DepartmentId" />
                        <input type="hidden" asp-for="Entity.AppUserId" />
                        <input type="hidden" asp-for="Entity.InsertDate" />
                        <input type="hidden" asp-for="Entity.UpdateDate" />
                        <input type="hidden" asp-for="Entity.InUse" />

                    </div>

                </div>

                <!-- Footer -->
                <div class="modal-footer bg-light">

                    <button type="button"
                            class="btn btn-outline-secondary px-4"
                            data-bs-dismiss="modal">

                        İptal

                    </button>

                    <button type="submit"
                            class="btn btn-success px-4 shadow-sm">

                        <ion-icon name="save-outline" class="me-1"></ion-icon>

                        @(Model.IsEdit ? "Güncelle" : "Kaydet")

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>