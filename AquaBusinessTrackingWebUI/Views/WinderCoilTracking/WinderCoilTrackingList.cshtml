@using DTOLayer.Dtos.WinderCoilTrackingDto

@{
    ViewData["Title"] = "WinderCoilTrackingList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
    int counter = 0;
}

@model List<WinderCoilTrackingDto>

<h6 class="mb-0 text-uppercase">Buffer / Kombin Takip Sistemi</h6>
<hr />

<div class="card">
    <div class="card-body">

        <div class="table-responsive">
            <table id="example2" class="table table-striped table-bordered">

                <thead>
                    <tr>
                        <th>#</th>
                        <th>Fiş Tarihi</th>
                        <th>Tampon No</th>
                        <th>Kağıt Tipi</th>
                        <th>Set No</th>
                        <th>Gramaj</th>
                        <th>Makine Hızı</th>
                        <th>Bobin Çapı</th>
                        <th>Çıkış Çapı</th>
                        <th>Boy (m)</th>
                        <th>Ek No</th>
                        <th>Vardiya</th>
                        <th>Kayıt Eden</th>
                        <th>Başlangıç</th>
                        <th>Bitiş</th>
                        <th>Kayıt Tarihi</th>
                        <th>Durum</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@counter</td>
                            <td>@item.ReceiptDate.ToString("dd.MM.yyyy")</td>
                            <td>@item.BufferNo</td>

                            <td>@item.PaperType</td>

                            <td>@item.SetNo</td>

                            <td>@item.Gramaj</td>

                            <td>@item.MachineSpeed</td>

                            <td>@item.CoilDiameter</td>

                            <td>@item.OutDiamater</td>

                            <td>@item.CoilLength</td>

                            <td>@item.AdditionalNumber</td>

                            <td>@item.ShiftName</td>

                            <td>@item.CreatedByName</td>

                            <td>
                                @(item.SetCutterStartDate.ToString("dd.MM.yyyy HH:mm"))
                            </td>

                            <td>
                                @(item.SetCutterEndDate.ToString("dd.MM.yyyy HH:mm"))
                            </td>

                            <td>
                                @(item.InsertDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                            </td>

                            <td>
                                @if (item.InUse == 1)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Pasif</span>
                                }
                            </td>

                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning"
                                        onclick="openModal(@item.RecId)">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                            </td>

                            <td class="text-center">
                                <form method="post"
                                      asp-action="DeleteBuffer"
                                      asp-route-id="@item.RecId"
                                      style="display:inline;">

                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Silinsin mi?');">
                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>

                                </form>
                            </td>

                        </tr>

                        counter++;
                    }
                </tbody>

                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Fiş Tarihi</th>
                        <th>Tampon No</th>
                        <th>Kağıt Tipi</th>
                        <th>Set No</th>
                        <th>Gramaj</th>
                        <th>Makine Hızı</th>
                        <th>Bobin Çapı</th>
                        <th>Çıkış Çapı</th>
                        <th>Boy (m)</th>
                        <th>Ek No</th>
                        <th>Vardiya</th>
                        <th>Kayıt Eden</th>
                        <th>Başlangıç</th>
                        <th>Bitiş</th>
                        <th>Kayıt Tarihi</th>
                        <th>Durum</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </tfoot>

            </table>
        </div>

        <button class="btn btn-primary shadow-sm" onclick="openModal()">
            <ion-icon name="add-circle-outline"></ion-icon>
            Yeni Kombin Ekle
        </button>

    </div>
</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/WinderCoilTracking/Edit/${id}`
            : `/WinderCoilTracking/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('coilTrackingModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/WinderCoilTracking/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>

