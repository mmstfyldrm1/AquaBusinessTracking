@using DTOLayer.Dtos.TestDtos.TestHeadDtos

@{
    ViewData["Title"] = "GetTestList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
}
@model List<TestHeadDto>

<h6 class="mb-0 text-uppercase">Endüstriyel Deneme İzleme Tablosu</h6>
<hr />

<div class="card">
    <div class="card-body">
        <div class="table-responsive">

            @{
                var counter = 1;
            }

            <table id="example2" class="table table-striped table-bordered">

                <thead>
                    <tr>
                        <th>#</th>
                        <th>Test Departman</th>
                        <th>Kullanıcı</th>
                        <th>Vardiya</th>
                        <th>Durum</th>
                        <th>Kayıt Tarihi</th>
                        <th>Kayıt Eden</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                        <th>Detay</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@counter</td>

                            <td>@item.TestDepartmentName</td>
                            <td>@item.CreatedByName</td>
                            <td>@item.ShiftName</td>

                            <td>
                                @if (item.InUse == 1)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Pasif</span>
                                }
                            </td>

                            <td>@item.InsertDate?.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@ViewBag.AppUserName</td>

                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning"
                                        onclick="openModal(@item.RecId)">
                                    <ion-icon name="create-outline"></ion-icon>
                                </button>
                            </td>

                            <td class="text-center">
                                <form method="post"
                                      asp-action="Delete"
                                      asp-route-id="@item.RecId"
                                      style="display:inline;">
                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Silinsin mi?');">
                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>
                                </form>
                            </td>

                            <td class="text-center">
                                <a href="/Test/Detail/@item.RecId"
                                   class="btn btn-sm btn-outline-info">
                                    <ion-icon name="eye-outline"></ion-icon>
                                </a>
                            </td>
                        </tr>

                        counter++;
                    }
                </tbody>

                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Test Departman</th>
                        <th>Kullanıcı</th>
                        <th>Vardiya</th>
                        <th>Durum</th>
                        <th>Kayıt Tarihi</th>
                        <th>Kayıt Eden</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                        <th>Detay</th>
                    </tr>
                </tfoot>

            </table>

        </div>

        <button class="btn btn-primary shadow-sm" onclick="openModal()">
            <ion-icon name="add-circle-outline"></ion-icon>
            Yeni Test Formu
        </button>

    </div>
</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/Test/Edit/${id}`
            : `/Test/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('testModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/Test/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>
