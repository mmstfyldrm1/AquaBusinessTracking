<style>
    @@media (max-width: 700px) {
        .pulper-grid {
            grid-template-columns: 1fr 1fr !important;
        }
    }

    @@media (max-width: 480px) {
        .pulper-grid {
            grid-template-columns: 1fr !important;
        }
    }

    .e-card {
        background: #fff;
        border: 0.5px solid #e8e8e6;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .e-hd {
        padding: .875rem 1.25rem;
        border-bottom: 0.5px solid #e8e8e6;
        font-size: 13px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .e-hd i {
            font-size: 16px;
            color: #888;
        }

    .pulper-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0,1fr));
        gap: 14px;
        padding: 1.25rem;
    }

    .pulper-card {
        background: #f8f8f6;
        border-radius: 10px;
        padding: 1rem;
        text-align: center;
    }

    .pulper-name {
        font-size: 12px;
        font-weight: 600;
        color: #555;
        margin-bottom: .75rem;
    }

    .tank {
        position: relative;
        width: 56px;
        height: 110px;
        margin: 0 auto .75rem;
        border: 2px solid #d8d8d4;
        border-radius: 8px;
        overflow: hidden;
        background: #fff;
    }

    .tank-fill {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        transition: height .4s ease;
    }

    .tank-pct {
        position: relative;
        z-index: 2;
        font-size: 13px;
        font-weight: 600;
        color: #333;
        line-height: 110px;
    }

    .fill-ok {
        background: #7FC97F;
    }

    .fill-warn {
        background: #F2C14E;
    }

    .fill-danger {
        background: #E8756A;
    }

    .pulper-meta {
        font-size: 11px;
        color: #999;
    }

    .e-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
        table-layout: fixed;
    }

        .e-table thead th {
            padding: .5rem 1rem;
            text-align: left;
            font-size: 11px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #aaa;
            background: #fafafa;
        }

            .e-table thead th:not(:first-child) {
                text-align: right;
            }

        .e-table tbody td {
            padding: .55rem 1rem;
            border-top: 0.5px solid #f0f0ee;
        }

            .e-table tbody td:not(:first-child) {
                text-align: right;
                font-variant-numeric: tabular-nums;
            }

        .e-table tbody tr:hover td {
            background: #fafafa;
        }

    .pill {
        display: inline-block;
        font-size: 11px;
        font-weight: 500;
        padding: 2px 7px;
        border-radius: 99px;
    }

    .pill-green {
        background: #EAF3DE;
        color: #3B6D11;
    }

    .pill-yellow {
        background: #FBF2DE;
        color: #8A6D1B;
    }

    .pill-red {
        background: #FBE4E1;
        color: #A5321C;
    }
</style>

<div class="page-section" id="pulper">

    <div class="e-card">
        <div class="e-hd"><i class="ti ti-droplet"></i>Pulper Seviyeleri</div>

        <div class="pulper-grid">

            <div class="pulper-card">
                <div class="pulper-name">Pulper 1</div>
                <div class="tank">
                    <div class="tank-fill fill-ok" style="height:82%"></div>
                    <div class="tank-pct">82%</div>
                </div>
                <div class="pulper-meta">4.100 / 5.000 kg</div>
            </div>

            <div class="pulper-card">
                <div class="pulper-name">Pulper 2</div>
                <div class="tank">
                    <div class="tank-fill fill-warn" style="height:45%"></div>
                    <div class="tank-pct">45%</div>
                </div>
                <div class="pulper-meta">2.250 / 5.000 kg</div>
            </div>

            <div class="pulper-card">
                <div class="pulper-name">Pulper 3</div>
                <div class="tank">
                    <div class="tank-fill fill-danger" style="height:18%"></div>
                    <div class="tank-pct">18%</div>
                </div>
                <div class="pulper-meta">900 / 5.000 kg</div>
            </div>

            <div class="pulper-card">
                <div class="pulper-name">Pulper 4</div>
                <div class="tank">
                    <div class="tank-fill fill-ok" style="height:95%"></div>
                    <div class="tank-pct">95%</div>
                </div>
                <div class="pulper-meta">4.750 / 5.000 kg</div>
            </div>

        </div>
    </div>

    <div class="e-card">
        <div class="e-hd"><i class="ti ti-list"></i>Pulper Detay Tablosu</div>
        <table class="e-table">
            <thead>
                <tr>
                    <th>Pulper</th>
                    <th>Mevcut (kg)</th>
                    <th>Kapasite (kg)</th>
                    <th>Doluluk</th>
                    <th>Durum</th>
                    <th>Son Güncelleme</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Pulper 1</td>
                    <td>4.100</td>
                    <td>5.000</td>
                    <td>82,0%</td>
                    <td><span class="pill pill-green">Dolu</span></td>
                    <td>08.07.2026 09:15</td>
                </tr>
                <tr>
                    <td>Pulper 2</td>
                    <td>2.250</td>
                    <td>5.000</td>
                    <td>45,0%</td>
                    <td><span class="pill pill-yellow">Orta</span></td>
                    <td>08.07.2026 09:15</td>
                </tr>
                <tr>
                    <td>Pulper 3</td>
                    <td>900</td>
                    <td>5.000</td>
                    <td>18,0%</td>
                    <td><span class="pill pill-red">Düşük</span></td>
                    <td>08.07.2026 09:15</td>
                </tr>
                <tr>
                    <td>Pulper 4</td>
                    <td>4.750</td>
                    <td>5.000</td>
                    <td>95,0%</td>
                    <td><span class="pill pill-green">Dolu</span></td>
                    <td>08.07.2026 09:15</td>
                </tr>
            </tbody>
        </table>
    </div>

</div>
