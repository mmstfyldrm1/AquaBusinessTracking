@using DTOLayer.Dtos.AdminDashboardDtos
@model RawMaterialsDto

<div class="page-section" id="hammadde">

    <div class="section-header">
        <div>
            <div class="section-title">🧪 Hammadde & Kimyasal</div>
            <div class="section-sub">
                Günlük tüketim ve stok hareketleri
            </div>
        </div>
    </div>

    <div class="row">

        <!-- Hurda Kağıt -->
        <div class="col-lg-6 mb-3">
            <div class="card h-100">
                <div class="card-title p-3">
                    Hurda Kağıt Tüketim
                </div>

                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Malzeme</th>
                                <th>Balya</th>
                                <th>Kg</th>
                                <th>Pulper</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model.DoughPreparation)
                            {
                                <tr>
                                    <td>@item.InventoryName</td>
                                    <td>@item.Bale</td>
                                    <td class="fw-bold text-primary">
                                        @item.KG.ToString("N2")
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">
                                            @item.PulperNo
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

        <!-- Kimyasal -->
        <div class="col-lg-6 mb-3">
            <div class="card h-100">
                <div class="card-title p-3">
                    Kimyasal Tüketim
                </div>

                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Malzeme</th>
                                <th>Gelen</th>
                                <th>Tüketilen</th>
                                <th>Kalan</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model.PapperMachineChemical)
                            {
                                <tr>
                                    <td>@item.InventoryName</td>

                                    <td class="text-success fw-bold">
                                        @item.IncomingQuantity.ToString("N2")
                                    </td>

                                    <td class="text-danger fw-bold">
                                        @item.ConsumedQuantity.ToString("N2")
                                    </td>

                                    <td class="text-primary fw-bold">
                                        @item.RemainingQuantity.ToString("N2")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

    </div>

</div>