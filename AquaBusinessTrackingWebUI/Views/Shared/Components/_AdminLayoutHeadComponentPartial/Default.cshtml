<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KM-2 Üretim Raporu</title>
    <style>
        /* RESET & BASE */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #ffffff;
            color: #1a1a2e;
        }

        /* TOP NAV */
        .topnav {
            position: sticky;
            top: 0;
            z-index: 100;
            background: #fff;
            border-bottom: 1px solid #e8e8ed;
            display: flex;
            gap: 10px;
            padding: 10px;
            overflow-x: auto;
            white-space: nowrap;
        }

            .topnav a {
                text-decoration: none;
                font-size: 12px;
                padding: 8px 12px;
                border-radius: 8px;
                color: #555;
                border: 1px solid #eee;
            }

                .topnav a:hover {
                    background: #eef4ff;
                    color: #185FA5;
                }

        /* CONTENT / SECTIONS */
        .content {
            padding: 20px;
        }

        .page-section {
            margin-bottom: 40px;
            scroll-margin-top: 70px;
        }

        .section-header {
            display: flex;
            gap: 10px;
            align-items: center;
            margin-bottom: 15px;
            border-bottom: 1px solid #e8e8ed;
            padding-bottom: 10px;
        }

        .section-title {
            font-size: 15px;
            font-weight: 600;
        }

        .section-sub {
            font-size: 12px;
            color: #888;
        }

        /* CARDS */
        .card {
            background: #fff;
            border: 1px solid #e8e8ed;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 15px;
            box-shadow: 0 2px 10px rgba(0, 0, 0, .08);
        }

        .card-title {
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 10px;
        }

        /* TABLES */
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }

        th, td {
            padding: 8px;
            border-bottom: 1px solid #f0f0f4;
            text-align: left;
            vertical-align: middle;
        }

        th {
            font-size: 10px;
            color: #999;
            text-transform: uppercase;
            background: #f8fafc;
            white-space: nowrap;
        }

        tr:hover td {
            background: #fafbff;
        }

        /* KPI CARDS */
        .kpi-grid {
            display: flex;
            gap: 12px;
            flex-wrap: nowrap;
            overflow-x: auto;
            margin-bottom: 15px;
        }

        .kpi {
            background: #fff;
            border: 1px solid #e8e8ed;
            border-radius: 10px;
            padding: 14px;
            min-width: 220px;
            flex: 1;
        }

        .kpi-label,
        .kpi-title {
            font-size: 11px;
            color: #888;
            margin-bottom: 6px;
        }

        .kpi-val,
        .kpi-value {
            font-size: 22px;
            font-weight: 600;
        }

        .kpi-unit {
            font-size: 11px;
            color: #aaa;
        }

        /* Status colors */
        .soft-green {
            color: #198754;
        }

        .soft-red {
            color: #dc3545;
        }

        .soft-blue {
            color: #0d6efd;
        }

        .soft-orange {
            color: #fd7e14;
        }

        /* CHARTS */
        .chart-wrap {
            height: 220px;
            font-size: 11px;
        }

        .chart-card {
            height: 420px;
            padding: 20px;
            flex: 1;
        }

        .chart-wrapper {
            position: relative;
            height: 300px;
            width: 100%;
        }

        .chart-wrap-small {
            height: 260px;
            position: relative;
        }

            .chart-wrap-small canvas {
                width: 100% !important;
                height: 100% !important;
            }

        #shippingChart {
            width: 100% !important;
            height: 350px !important;
            display: block;
        }

        /* TWO-COLUMN / STOCK LAYOUTS */
        .stock-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .stock-card {
            border-radius: 14px;
            overflow: hidden;
        }

        .stock-table {
            width: 100%;
            border-collapse: collapse;
        }

            .stock-table th {
                background: #f5f7fa;
                padding: 12px;
                font-weight: 600;
                border-bottom: 1px solid #e5e7eb;
            }

            .stock-table td {
                padding: 12px;
                border-bottom: 1px solid #f1f1f1;
            }

            .stock-table tbody tr:hover {
                background: #fafafa;
            }

        .stock-row {
            display: flex;
            gap: 20px;
        }

            .stock-row .card {
                flex: 1;
            }

        /* SEVKİYAT LAYOUT */
        .sevk-layout {
            display: flex;
            gap: 20px;
            align-items: stretch;
        }

        .table-card {
            flex: 1.5;
        }

        /* ÖZET LAYOUT */
        .ozet-layout {
            display: flex;
            gap: 20px;
            align-items: stretch;
        }

            .ozet-layout .chart-card {
                flex: 1;
            }

        /* RESPONSIVE */
        @@media (max-width: 992px) {
            .stock-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 768px) {
            .ozet-layout {
                flex-direction: column;
            }

            .chart-wrap-small {
                height: 200px;
            }
        }
    </style>
</head>
