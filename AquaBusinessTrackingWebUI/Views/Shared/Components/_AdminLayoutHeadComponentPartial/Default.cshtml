<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KM-2 Üretim Raporu</title>
    <style>
        .card {
            border: none;
            border-radius: 14px;
            box-shadow: 0 2px 10px rgba(0,0,0,.08);
        }

        .card-title {
            font-size: 16px;
            font-weight: 600;
        }

        .table th {
            background: #f8fafc;
            white-space: nowrap;
        }

        .table td {
            vertical-align: middle;
        }

        .kpi-card {
            border: 1px solid #eee;
            border-radius: 12px;
            background: #fff;
        }

        .kpi-title {
            font-size: 13px;
            color: #6c757d;
            margin-bottom: 5px;
        }

        .kpi-value {
            font-size: 22px;
            font-weight: 600;
        }

        .soft-green {
            color: #198754;
        }

        .soft-red {
            color: #dc3545;
        }

        .soft-blue {
            color: #0d6efd;
        }

        .soft-orange {
            color: #fd7e14;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        body {
            font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
            background: #FFFFFF;
            color: #1a1a2e;
        }


        .topnav {
            position: sticky;
            top: 0;
            z-index: 100;
            background: #fff;
            border-bottom: 1px solid #e8e8ed;
            display: flex;
            gap: 10px;
            padding: 10px;
            overflow-x: auto;
            white-space: nowrap;
        }

            .topnav a {
                text-decoration: none;
                font-size: 12px;
                padding: 8px 12px;
                border-radius: 8px;
                color: #555;
                border: 1px solid #eee;
            }

                .topnav a:hover {
                    background: #eef4ff;
                    color: #185FA5;
                }

        /* CONTENT */
        .content {
            padding: 20px;
        }

        .page-section {
            margin-bottom: 40px;
            scroll-margin-top: 70px;
        }

        .section-header {
            display: flex;
            gap: 10px;
            align-items: center;
            margin-bottom: 15px;
            border-bottom: 1px solid #e8e8ed;
            padding-bottom: 10px;
        }

        .section-title {
            font-size: 15px;
            font-weight: 600;
        }

        .section-sub {
            font-size: 12px;
            color: #888;
        }

        /* CARDS / TABLES (KEEP YOUR ORIGINAL STYLE LIGHTLY SIMPLIFIED) */
        .card {
            background: #fff;
            border: 1px solid #e8e8ed;
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 15px;
        }

        .card-title {
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 10px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }

        th, td {
            padding: 8px;
            border-bottom: 1px solid #f0f0f4;
            text-align: left;
        }

        th {
            font-size: 10px;
            color: #999;
            text-transform: uppercase;
        }

        tr:hover td {
            background: #fafbff;
        }

        /* CHART */
        .chart-wrap {
            height: 220px;
        }



        {
            font-size: 11px
        }

        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 12px;
            margin-bottom: 15px;
        }

        .kpi {
            background: #fff;
            border: 1px solid #e8e8ed;
            border-radius: 10px;
            padding: 14px;
        }

        .kpi-label {
            font-size: 11px;
            color: #888;
            margin-bottom: 6px;
        }

        .kpi-val {
            font-size: 22px;
            font-weight: 600;
        }

        .kpi-unit {
            font-size: 11px;
            color: #aaa;
        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 12px;
            width: 100%;
        }

        .kpi-grid {
            display: flex;
            gap: 12px;
            flex-wrap: nowrap; /* TEK SATIR ZORUNLU */
            overflow-x: auto; /* taşarsa scroll */
        }

        .kpi {
            min-width: 220px;
            flex: 1;
        }

        .chart-card {
            height: 450px;
        }

        .chart-wrapper {
            position: relative;
            height: 300px;
            width: 100%;
        }

        .chart-card {
            height: 420px;
            padding: 20px;
        }

        #shippingChart {
            width: 100% !important;
            height: 350px !important;
            display: block;
        }


        .stock-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .stock-card {
            border-radius: 14px;
            overflow: hidden;
        }

        .stock-table {
            width: 100%;
            border-collapse: collapse;
        }

            .stock-table th {
                background: #f5f7fa;
                padding: 12px;
                font-weight: 600;
                border-bottom: 1px solid #e5e7eb;
            }

            .stock-table td {
                padding: 12px;
                border-bottom: 1px solid #f1f1f1;
            }

            .stock-table tbody tr:hover {
                background: #fafafa;
            }

        @@media(max-width: 992px) {
            .stock-grid {
                grid-template-columns: 1fr;
            }
        }

        .stock-row {
            display: flex;
            gap: 20px;
        }

            .stock-row .card {
                flex: 1;
            }



        .sevk-layout {
            display: flex;
            gap: 20px;
            align-items: stretch;
        }

        /* Grafik kartı */
        .chart-card {
            flex: 1;
        }

        /* Tablo kartı */
        .table-card {
            flex: 1.5;
        }

        /* Grafik yüksekliğini gerçekten sabitle */
        .chart-wrapper-small {
            height: 260px;
            position: relative;
        }

            /* canvas zorla dolsun */
            .chart-wrapper-small canvas {
                width: 100% !important;
                height: 100% !important;
            }


        .ozet-layout {
            display: flex;
            gap: 20px;
            align-items: stretch;
        }

            /* Kartlar eşit dağılsın */
            .ozet-layout .chart-card {
                flex: 1;
            }

        /* Grafik yüksekliği SABİT */
        .chart-wrap-small {
            height: 260px;
            position: relative;
        }

            /* Canvas tam dolsun */
            .chart-wrap-small canvas {
                width: 100% !important;
                height: 100% !important;
            }

        @@media (max-width: 768px) {
            .ozet-layout {
                flex-direction: column;
            }

            .chart-wrap-small {
                height: 200px;
            }
        }


    </style>
</head>