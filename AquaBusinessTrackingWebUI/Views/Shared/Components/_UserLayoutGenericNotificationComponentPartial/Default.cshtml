@if (TempData["Success"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            Lobibox.notify('success', {
                msg: '@TempData["Success"]',
                position: 'top right',
                delay: 3000,
                rounded: true,
                icon: true
            });
        });
    </script>
}
