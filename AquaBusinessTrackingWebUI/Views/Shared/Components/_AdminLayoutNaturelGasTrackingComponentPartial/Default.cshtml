@model NaturelGasProductionViewModel

<style>
    @@media (max-width: 600px) {
        .kpi-row {
            grid-template-columns: 1fr !important;
        }
    }

    @@media (max-width: 700px) {
        .two-col {
            grid-template-columns: 1fr !important;
        }
    }

    @@media (max-width: 480px) {
        .chart-wrap {
            height: 180px;
        }
    }

    @@media (max-width: 400px) {
        .hide-xs {
            display: none;
        }

        .e-table thead th,
        .e-table tbody td {
            padding: .5rem .75rem;
        }
    }

    .kpi-row {
        display: grid;
        grid-template-columns: repeat(3, minmax(0,1fr));
        gap: 12px;
        margin-bottom: 1.5rem;
    }

    .kpi-card {
        background: #f8f8f6;
        border-radius: 8px;
        padding: 1rem;
    }

    .kpi-lbl {
        font-size: 12px;
        color: #888;
        margin-bottom: 4px;
    }

    .kpi-val {
        font-size: 22px;
        font-weight: 500;
        line-height: 1.1;
    }

    .kpi-unit {
        font-size: 12px;
        color: #aaa;
        margin-top: 2px;
    }
    .pill {
        display: inline-block;
        font-size: 11px;
        font-weight: 500;
        padding: 2px 7px;
        border-radius: 99px;
    }

    .pill-blue {
        background: #E6F1FB;
        color: #185FA5;
    }

    .pill-green {
        background: #EAF3DE;
        color: #3B6D11;
    }
</style>

@{
    var last7Days = Enumerable.Range(0, 7)
           .Select(i => DateTime.Today.AddDays(-6 + i))
           .ToList();

    var chartLabels = last7Days
        .Select(d => d.ToString("dd.MM"))
        .ToList();

    var chartProd = last7Days
        .Select(d => Model.Remaning.FirstOrDefault(x => x.Date.Date == d.Date)?.Remaning ?? 0)
        .ToList();

    var chartgas = last7Days
        .Select(d => Model.DailyStats.FirstOrDefault(x => x.Date.Date == d.Date)?.NaturelGas ?? 0)
        .ToList();
}

<div class="page-section" id="dogalgaz">

    <div class="kpi-row">
        <div class="kpi-card">
            <div class="kpi-lbl">Son 30 Gün Üretim</div>
            <div class="kpi-val">@((Model.TotalRemaning).ToString("N2"))</div>
            <div class="kpi-unit">Kg</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-lbl">Toplam Doğal Gaz</div>
            <div class="kpi-val">@Model.TotalGas.ToString("N2")</div>
            <div class="kpi-unit">m³</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-lbl">Kg Başına Gaz</div>
            <div class="kpi-val">@Model.KwhPerTon.ToString("N2")</div>
            <div class="kpi-unit">m³ / Kg</div>
        </div>
    </div>

    <div class="row">
        <!-- Grafik Kartı -->
        <div class="col-12 mb-3">
            <div class="card h-100">
                <div class="card-title p-3">
                    <i class="ti ti-chart-bar"></i> Günlük Üretim &amp; Doğal Gaz
                </div>
                <div style="display:flex;gap:12px;padding:.75rem 1.25rem;font-size:12px;color:#888">
                    <span>
                        <span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:#378ADD;margin-right:4px"></span>
                        Üretim (Kg)
                    </span>
                    <span>
                        <span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:#F09595;margin-right:4px"></span>
                        Doğal Gaz (m³)
                    </span>
                </div>
                <div class="chart-wrap">
                    <canvas id="gasChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Doğal Gaz Tüketim Kartı -->
        <div class="col-lg-6 mb-3">
            <div class="card h-100">
                <div class="card-title p-3">
                    <i class="ti ti-flame"></i> Doğal Gaz Tüketimi (Son 7 Gün)
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Tarih</th>
                                <th>Tüketim (m³)</th>
                                <th>kW</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.NaturelGas.OrderByDescending(x => x.ReceiptDate).Take(7).OrderBy(x => x.ReceiptDate))
                            {
                                <tr>
                                    <td>@item.ReceiptDate.ToString("dd.MM")</td>
                                    <td>@item.DailyConsumption.ToString("N2") m³</td>
                                    <td>@item.kW.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr class="fw-bold">
                                <td>Toplam</td>
                                <td>@Model.NaturelGas.OrderByDescending(x => x.ReceiptDate).Take(7).Sum(x => x.DailyConsumption).ToString("N2") m³</td>
                                <td>@Model.NaturelGas.OrderByDescending(x => x.ReceiptDate).Take(7).Sum(x => x.kW).ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- 7 Günlük Üretim Kartı -->
        <div class="col-lg-6 mb-3">
            <div class="card h-100">
                <div class="card-title p-3">
                    <i class="ti ti-package"></i> 7 Günlük Üretim
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Tarih</th>
                                <th>Üretim</th>
                                <th>m³/Kg</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Remaning.OrderByDescending(x => x.Date).Take(7).OrderBy(x => x.Date))
                            {
                                var daily = Model.DailyStats.FirstOrDefault(x => x.Date.Date == item.Date.Date);
                                <tr>
                                    <td>@item.Date.ToString("dd.MM")</td>
                                    <td class="text-success">@item.Production.ToString("N2")</td>
                                    <td>@((daily?.KwhPerTon ?? 0).ToString("N3")) m³/Kg</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr class="fw-bold">
                                <td>Toplam</td>
                                <td class="text-success" >@Model.Remaning.OrderByDescending(x => x.Date).Take(7).Sum(x => x.Production).ToString("N2")</td>
                                <td>
                                    @{
                                        var totalM3 = Model.DailyStats
                                        .Where(x => Model.Remaning.Select(r => r.Date.Date).Contains(x.Date.Date))
                                        .Sum(x => x.KwhPerTon * x.Production);
                                        var totalProduction = Model.Remaning.OrderByDescending(x => x.Date).Take(7).Sum(x => x.Production);
                                        var avgM3PerKg = totalProduction > 0 ? (totalM3 / totalProduction) : 0;
                                    }
                                    @avgM3PerKg.ToString("N3") m³/Kg
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>

           document.addEventListener('DOMContentLoaded', function () {

        const labels = @Html.Raw(Json.Serialize(chartLabels));
        const prodVal = @Html.Raw(Json.Serialize(chartProd));
        const energyVal = @Html.Raw(Json.Serialize(chartgas));

        const existing = Chart.getChart('gasChart');
        if (existing) existing.destroy();

        new Chart(document.getElementById('gasChart'), {
            type: 'bar',
            data: {
                labels,
                datasets: [
                    { label: 'Üretim (ton)', data: prodVal, backgroundColor: '#378ADD', yAxisID: 'y' },
                    { label: 'Doğal Gaz (m³)', data: energyVal, backgroundColor: '#F09595', yAxisID: 'y1' }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: true } },
                scales: {
                    y: { position: 'left', grid: { color: 'rgba(0,0,0,0.06)' } },
                    y1: { position: 'right', grid: { drawOnChartArea: false } }
                }
            }
        });
    });
</script>