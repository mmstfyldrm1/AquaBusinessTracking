@{
    ViewData["Title"] = "GetPurificationChemicalsList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
}

<h6 class="mb-0 text-uppercase">Arıtma Kimyasal Tüketim(Kg)</h6>
<hr />

<div class="card">
    <div class="card-body">
        <div class="table-responsive">

            @{
                var counter = 1;
            }

            <table id="example2" class="table table-striped table-bordered">

                <thead>
                    <tr>
                        <th>#</th>
                        <th>Malzeme Kodu</th>
                        <th>Malzeme Adı</th>
                        <th>Ay</th>
                        <th>Gelen</th>
                        <th>Tüketilen</th>
                        <th>Kalan</th>
                        <th>Vardiya</th>
                        <th>Durum</th>
                        <th>Kayıt Tarihi</th>
                        <th>Kayıt Eden</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@counter</td>

                            <td>@item.InventoryCode</td>
                            <td>@item.InventoryName</td>
                            <td>@item.Month</td>

                            <td>@item.IncomingQuantity</td>
                            <td>@item.ConsumedQuantity</td>
                            <td>@item.RemainingQuantity</td>


                            <td>@item.ShiftName</td>

                            <td>
                                @if (item.InUse == 1)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Pasif</span>
                                }
                            </td>

                            <td>@item.InsertDate?.ToString("dd.MM.yyyy HH:mm")</td>

                            <td>@item.CreatedByName</td>

                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning px-2 py-1"
                                        onclick="openModal(@item.RecId)">
                                    <i class="bi bi-pencil-square fs-6"></i>
                                </button>
                            </td>

                            <td class="text-center">
                                <form method="post" asp-action="Delete" asp-route-id="@item.RecId" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Silinsin mi?');">
                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>
                                </form>
                            </td>
                        </tr>

                        counter++;
                    }
                </tbody>

                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Malzeme Kodu</th>
                        <th>Malzeme Adı</th>
                        <th>Ay</th>
                        <th>Gelen</th>
                        <th>Tüketilen</th>
                        <th>Kalan</th>
                        <th>Vardiya</th>
                        <th>Durum</th>
                        <th>Kayıt Tarihi</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </tfoot>

            </table>

        </div>

        <button class="btn btn-primary shadow-sm" onclick="openModal()">
            <ion-icon name="add-circle-outline"></ion-icon>
            Yeni Kayıt Ekle
        </button>

    </div>
</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/PurificationChemicalsConsumption/Edit/${id}`
            : `/PurificationChemicalsConsumption/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('purificationChemicalsConsumptionModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/PurificationChemicalsConsumption/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>
