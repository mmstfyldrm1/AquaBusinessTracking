    <div class="section-header-icon ic-sky"><i class="bx bx-cloud"></i></div>
    <h6>Buhar Tüketim</h6>
</div>
<div class="data-card card">
    <div class="card-body">
        <div class="table-responsive">
            <table id="tbl-buhar" class="data-table table table-striped">
                <thead>
