@using DTOLayer.Dtos.PlanningDto

@{
    ViewData["Title"] = "Günlük Tüketim Raporu";
    Layout = "~/Views/_UserLayout/Index.cshtml";
}
@model PlanningDto

<style>
    /* ── Page header ── */
    .page-header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0 0 1.5rem;
        border-bottom: 1px solid #e9ecef;
        margin-bottom: 1.75rem;
    }

    .page-header-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: #e7f0fd;
        color: #2563eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        flex-shrink: 0;
    }

    .page-header h4 {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 700;
        color: #1a1d23;
        line-height: 1.2;
    }

    .page-header p {
        margin: 0;
        font-size: 0.78rem;
        color: #6c757d;
    }

    /* ── Section dividers ── */
    .section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 2rem 0 0.65rem;
    }

    .section-header-icon {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .section-header h6 {
        margin: 0;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: #374151;
    }

    /* ── Card ── */
    .data-card {
        border: 1px solid #e9ecef;
        border-radius: 10px;
        box-shadow: 0 1px 3px rgba(0,0,0,.04);
        margin-bottom: 1.5rem;
        overflow: hidden;
    }

        .data-card .card-body {
            padding: 0;
        }

    /* ── Table ── */
    .data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.825rem;
    }

        .data-table thead tr {
            background: #f8f9fc;
        }

        .data-table thead th {
            padding: 10px 14px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #6b7280;
            border-bottom: 1px solid #e5e7eb;
            white-space: nowrap;
        }

        .data-table tbody tr {
            border-bottom: 1px solid #f1f3f7;
            transition: background 0.12s;
        }

            .data-table tbody tr:last-child {
                border-bottom: none;
            }

            .data-table tbody tr:hover {
                background: #f8f9fc;
            }

        .data-table tbody td {
            padding: 9px 14px;
            vertical-align: middle;
            color: #374151;
        }

        .data-table tfoot tr {
            background: #f8f9fc;
            border-top: 2px solid #e5e7eb;
        }

        .data-table tfoot th {
            padding: 8px 14px;
            font-size: 0.68rem;
            font-weight: 600;
            color: #9ca3af;
            white-space: nowrap;
        }

    /* ── Row number ── */
    .row-num {
        color: #9ca3af;
        font-size: 0.72rem;
        font-weight: 600;
        min-width: 24px;
    }

    /* ── Badges ── */
    .badge-aktif {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        background: #dcfce7;
        color: #15803d;
    }

    .badge-pasif {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        background: #f1f5f9;
        color: #64748b;
    }

    .badge-uygun {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        background: #dcfce7;
        color: #15803d;
    }

    .badge-uygun-degil {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        background: #fee2e2;
        color: #b91c1c;
    }

    .badge-onay {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        background: #dcfce7;
        color: #15803d;
    }

    .badge-bekle {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        background: #fef9c3;
        color: #a16207;
    }

    .badge-nem {
        display: inline-flex;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        background: #e0f2fe;
        color: #0369a1;
    }

    .badge-yabanci {
        display: inline-flex;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        background: #fef9c3;
        color: #a16207;
    }

    /* ── Numeric cell ── */
    .num-cell {
        font-variant-numeric: tabular-nums;
        text-align: right;
    }

    /* ── Icon colors per section ── */
    .ic-blue {
        background: #e7f0fd;
        color: #2563eb;
    }

    .ic-green {
        background: #dcfce7;
        color: #16a34a;
    }

    .ic-teal {
        background: #ccfbf1;
        color: #0f766e;
    }

    .ic-orange {
        background: #ffedd5;
        color: #c2410c;
    }

    .ic-red {
        background: #fee2e2;
        color: #b91c1c;
    }

    .ic-sky {
        background: #e0f2fe;
        color: #0284c7;
    }

    .ic-violet {
        background: #ede9fe;
        color: #6d28d9;
    }

    .ic-amber {
        background: #fef3c7;
        color: #d97706;
    }

    .ic-indigo {
        background: #e0e7ff;
        color: #4338ca;
    }

    .ic-gray {
        background: #f1f5f9;
        color: #64748b;
    }
</style>


@* ── PAGE HEADER ── *@
<div class="page-header">
    <div class="page-header-icon">
        <i class="bx bx-clipboard"></i>
    </div>
    <div>
        <h4>Günlük Tüketim Raporu</h4>
        <p>Tüm üretim ve tüketim verilerinin günlük özeti</p>
    </div>
</div>


@* ══════════════════════════════════════════════
   1. ATIK KAĞIT KONTROL
   ══════════════════════════════════════════════ *@
<div class="section-header">
    <div class="section-header-icon ic-blue"><i class="bx bx-recycle"></i></div>
    <h6>Atık Kağıt Kontrol</h6>
</div>
<div class="data-card card">
    <div class="card-body">
        <div class="table-responsive">
            <table id="tbl-atik-kagit" class="data-table table table-striped">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Sıra No</th>
                        <th>Tarih</th>
                        <th>İrsaliye No</th>
                        <th>Firma</th>
                        <th>Plaka</th>
                        <th>Balya</th>
                        <th>Kağıt Türü</th>
                        <th class="text-end">İrsaliye Kg</th>
                        <th class="text-end">Brüt Giriş Kg</th>
                        <th class="text-end">Net Fatura Kg</th>
                        <th class="text-center">Nem Ort. %</th>
                        <th class="text-center">Yabancı Madde %</th>
                        <th>Vardiya</th>
                        <th>Kayıt Eden</th>
                        <th>Kayıt Tarihi</th>
                        <th>Güncelleme</th>
                        <th class="text-center">Durum</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i1 = 1;
                    }
                    @foreach (var item in Model.WastePaperControls)
                    {
                        <tr>
                            <td class="row-num">@i1</td>
                            <td>@item.SequenceNumber</td>
                            <td>@item.ReceiptDate.ToString("dd.MM.yyyy")</td>
                            <td><code style="font-size:0.78rem;color:#4b5563;">@item.WaybillNumber</code></td>
                            <td><strong style="font-weight:600;">@item.Company</strong></td>
                            <td><span style="font-family:monospace;font-size:0.78rem;">@item.VehicleLicensePlate</span></td>
                            <td class="num-cell">@item.NumberOfBales</td>
                            <td>@item.ReceivedPaperType</td>
                            <td class="num-cell">@item.WaybillQuantityKg</td>
                            <td class="num-cell">@item.GrossEntryQuantityKg</td>
                            <td class="num-cell">@item.NetInvoiceBaseKg</td>
                            <td class="text-center"><span class="badge-nem">@item.AverageMoisturePercent %</span></td>
                            <td class="text-center"><span class="badge-yabanci">@item.ForeignMaterialPercent %</span></td>
                            <td>@(item.ShiftName ?? "-")</td>
                            <td>@(item.CreatedByName ?? "-")</td>
                            <td style="color:#6b7280;font-size:0.78rem;">@(item.InsertDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                            <td style="color:#6b7280;font-size:0.78rem;">@(item.UpdateDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                            <td class="text-center">
                                @if (item.InUse == 1)
                                {
                                    <span class="badge-aktif"><i class="bx bx-check-circle" style="font-size:12px;"></i>Aktif</span>
                                }
                                else
                                {

                                    <span class="badge-pasif">Pasif</span>
                                }
                            </td>
                        </tr>
                        i1++;
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Sıra No</th>
                        <th>Tarih</th>
                        <th>İrsaliye No</th>
                        <th>Firma</th>
                        <th>Plaka</th>
                        <th>Balya</th>
                        <th>Kağıt Türü</th>
                        <th>İrsaliye Kg</th>
                        <th>Brüt Giriş Kg</th>
                        <th>Net Fatura Kg</th>
                        <th>Nem Ort.</th>
                        <th>Yabancı Madde</th>
                        <th>Vardiya</th>
                        <th>Kayıt Eden</th>
                        <th>Kayıt Tarihi</th>
                        <th>Güncelleme</th>
                        <th>Durum</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>


@* ══════════════════════════════════════════════
   2. HAMUR HAZIRLAMA KAĞIT TÜKETİM
   ══════════════════════════════════════════════ *@
<div class="section-header">
    <div class="section-header-icon ic-teal"><i class="bx bx-layer"></i></div>
    <h6>Hamur Hazırlama Kağıt Tüketim</h6>
</div>
<div class="data-card card">
    <div class="card-body">
        <div class="table-responsive">
            <table id="tbl-hamur" class="data-table table table-striped">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tarih</th>
                        <th>Pulper No</th>
                        <th>Stok Kodu</th>
                        <th>Stok Adı</th>
                        <th>Sıra No</th>
                        <th class="text-end">Kırpıntı</th>
                        <th class="text-end">Balya</th>
                        <th class="text-end">KG</th>
                        <th>Kayıt Tarihi</th>
                        <th>Kayıt Eden</th>
                        <th>Vardiya</th>
                        <th>Güncelleme Tarihi</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i2 = 1;
                    }
                    @foreach (var item in Model.DoughPreparations)
                    {
                        <tr>
                            <td class="row-num">@i2</td>
                            <td>@item.ReceiptDate.ToString("dd.MM.yyyy")</td>
                            <td><span style="font-weight:600;color:#0f766e;">@item.PulperNo</span></td>
                            <td><code style="font-size:0.78rem;color:#4b5563;">@item.InventoryCode</code></td>
                            <td>@item.InventoryName</td>
                            <td>@item.QueueNo</td>
                            <td class="num-cell">@item.Clippings</td>
                            <td class="num-cell">@item.Bale</td>
                            <td class="num-cell"><strong style="font-weight:600;">@item.KG</strong></td>
                            <td style="color:#6b7280;font-size:0.78rem;">@(item.InsertDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                            <td>@(item.CreatedByName ?? "-")</td>
                            <td>@(item.ShiftName ?? "-")</td>
                            <td style="color:#6b7280;font-size:0.78rem;">@(item.UpdateDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                        </tr>
                        i2++;
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Tarih</th>
                        <th>Pulper No</th>
                        <th>Stok Kodu</th>
                        <th>Stok Adı</th>
                        <th>Sıra No</th>
                        <th>Kırpıntı</th>
                        <th>Balya</th>
                        <th>KG</th>
                        <th>Kayıt Tarihi</th>
                        <th>Kayıt Eden</th>
                        <th>Vardiya</th>
                        <th>Güncelleme Tarihi</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>


@* ══════════════════════════════════════════════
   3. KAĞIT MAKİNESİ KİMYASALLARI
   ══════════════════════════════════════════════ *@
<div class="section-header">
    <div class="section-header-icon ic-violet"><i class="bx bx-test-tube"></i></div>
    <h6>Kağıt Makinesi Kimyasalları</h6>
</div>
<div class="data-card card">
    <div class="card-body">
        <div class="table-responsive">
            <table id="tbl-km-kimya" class="data-table table table-striped">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Stok Kodu</th>
                        <th>Stok Adı</th>
                        <th class="text-end">Gelen</th>
                        <th class="text-end">Tüketilen</th>
                        <th class="text-end">Kalan</th>
                        <th>Tarih</th>
                        <th>Kullanıcı</th>
                        <th>Vardiya</th>
                        <th class="text-center">Durum</th>
                        <th>Kayıt Tarihi</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i3 = 1;
                    }
                    @foreach (var item in Model.PapperMachineChemicals)
                    {
                        <tr>
                            <td class="row-num">@i3</td>
                            <td><code style="font-size:0.78rem;color:#4b5563;">@(item.InventoryCode ?? "-")</code></td>
                            <td>@(item.InventoryName ?? "-")</td>
                            <td class="num-cell">@item.IncomingQuantity.ToString("N2")</td>
                            <td class="num-cell" style="color:#b91c1c;">@item.ConsumedQuantity.ToString("N2")</td>
                            <td class="num-cell" style="color:#15803d;font-weight:600;">@item.RemainingQuantity.ToString("N2")</td>
                            <td>@(item.ReceiptDate.ToString("dd.MM.yyyy") ?? "-")</td>
                            <td>@(item.CreatedByName ?? "-")</td>
                            <td>@(item.ShiftName ?? "-")</td>
                            <td class="text-center">
                                @if (item.InUse == 1)
                                {
                                    <span class="badge-aktif"><i class="bx bx-check-circle" style="font-size:12px;"></i>Aktif</span>
                                }
                                else
                                {

                                    <span class="badge-pasif">Pasif</span>
                                }
                            </td>
                            <td style="color:#6b7280;font-size:0.78rem;">@(item.InsertDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                        </tr>
                        i3++;
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Stok Kodu</th>
                        <th>Stok Adı</th>
                        <th>Gelen</th>
                        <th>Tüketilen</th>
                        <th>Kalan</th>
                        <th>Tarih</th>
                        <th>Kullanıcı</th>
                        <th>Vardiya</th>
                        <th>Durum</th>
                        <th>Kayıt Tarihi</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>


@* ══════════════════════════════════════════════
   4. SU HAZIRLAMA VE TÜKETİM
   ══════════════════════════════════════════════ *@
<div class="section-header">
    <div class="section-header-icon ic-sky"><i class="bx bx-droplet"></i></div>
    <h6>Su Hazırlama ve Tüketim</h6>
</div>
<div class="data-card card">
    <div class="card-body">
        <div class="table-responsive">
            <table id="tbl-su-hazir" class="data-table table table-striped">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Malzeme Kodu</th>
                        <th>Malzeme Adı</th>
                        <th>Ay</th>
                        <th class="text-end">Gelen</th>
                        <th class="text-end">Tüketilen</th>
                        <th class="text-end">Kalan</th>
                        <th>Vardiya</th>
                        <th class="text-center">Durum</th>
                        <th>Kayıt Tarihi</th>
                        <th>Kayıt Eden</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i4 = 1;
