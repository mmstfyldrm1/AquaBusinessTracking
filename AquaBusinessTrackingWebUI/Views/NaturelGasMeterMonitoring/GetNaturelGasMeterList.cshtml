@using DTOLayer.Dtos.NaturelGasMeterMonitoringDtos

@{
    ViewData["Title"] = "GetNaturelGasMeterList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
    int counter = 1;
}

@model List<NaturelGasMeterMonitoringDto>

<h6 class="mb-0 text-uppercase">Enerji / Gaz Tüketim Takip Sistemi</h6>
<hr />

<div class="card">
    <div class="card-body">
        <div class="table-responsive">

            <table id="example2" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tarih</th>

                        <th>Günlük Tüketim</th>
                        <th>Basınç</th>
                        <th>Isı</th>
                        <th>Kalorifik Değer</th>

                        <th>Standart m³</th>
                        <th>Çevrim Faktörü</th>

                        <th>kW</th>
                        <th>Açıklama</th>

                        <th>Kontrol</th>
                        <th>Onay</th>

                        <th>Vardiya</th>
                        <th>Kayıt Eden</th>
                        <th>Kayıt Tarihi</th>

                        <th>Durum</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@counter</td>

                            <td>@item.Date.ToString("dd.MM.yyyy")</td>

                            <td>@item.DailyConsumption</td>
                            <td>@item.Pressure</td>
                            <td>@item.Heat</td>
                            <td>@item.CalorificValue</td>

                            <td>@item.StandartCubicmeter</td>
                            <td>@item.ConversionFactor</td>

                            <td>@item.kW</td>

                            <td>@item.Explanation</td>

                            <td>@item.Control</td>

                            <td>
                                @(item.IsApproved == 1 ? "Onaylı" : "Beklemede")
                            </td>

                            <td>@item.ShiftName</td>
                            <td>@item.CreatedByName</td>

                            <td>
                                @(item.InsertDate.HasValue
                                                            ? item.InsertDate.Value.ToString("dd.MM.yyyy HH:mm")
                                                            : "-")
                        </td>

                            <td>

                            @if (item.InUse == 1)
                                {
                                    <span class="badge bg-success">
                                        Aktif
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Pasif
                                    </span>
                                }

                            </td>

                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning px-2 py-1"
                                        onclick="openModal(@item.RecId)">
                                    <i class="bi bi-pencil-square fs-6"></i>
                                </button>
                            </td>

                            <td class="text-center">
                                <form method="post"
                                      asp-action="Delete"
                                      asp-route-id="@item.RecId"
                                      style="display:inline;">
                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Silinsin mi?');">
                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>
                                </form>
                            </td>

                        </tr>

                                        counter++;
                    }
                </tbody>

                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Tarih</th>

                        <th>Günlük Tüketim</th>
                        <th>Basınç</th>
                        <th>Isı</th>
                        <th>Kalorifik Değer</th>

                        <th>Standart m³</th>
                        <th>Çevrim Faktörü</th>

                        <th>kW</th>
                        <th>Açıklama</th>

                        <th>Kontrol</th>
                        <th>Onay</th>

                        <th>Vardiya</th>
                        <th>Kayıt Eden</th>
                        <th>Kayıt Tarihi</th>

                        <th>Durum</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </tfoot>

            </table>

        </div>

        <button class="btn btn-primary shadow-sm" onclick="openModal()">
            <ion-icon name="add-circle-outline"></ion-icon>
            Yeni Kayıt Ekle
        </button>

    </div>
</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/NaturelGasMeterMonitoring/Edit/${id}`
            : `/NaturelGasMeterMonitoring/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('NaturelGasMeterMonitoringModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/NaturelGasMeterMonitoring/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>
