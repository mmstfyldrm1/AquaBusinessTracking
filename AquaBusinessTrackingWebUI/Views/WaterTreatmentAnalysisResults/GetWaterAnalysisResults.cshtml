@using DTOLayer.Dtos.WaterTreatmentAnalysisResultsDtos

@{
    ViewData["Title"] = "GetWaterAnalysisResults";
    Layout = "~/Views/_UserLayout/Index.cshtml";
}
@model List<WaterTreatmentAnalysisResultsDto>
<h6 class="mb-0 text-uppercase">Su Arıtma Analiz Sonuçları</h6>
<hr />

<div class="card">
    <div class="card-body">

        <div class="table-responsive">

            <table id="example2" class="table table-striped table-bordered">

                <thead>
                    <tr>
                        <th>#</th>
                        <th>Fiş Tarihi</th>
                        <th>Numune Alma Süresi (dk)</th>
                        <th>Sonuç Teslim Süresi (dk)</th>
                        <th>Numune Alınan Yer</th>
                        <th>Kuru Madde (%)</th>
                        <th>Doluluk</th>
                        <th>Açıklama</th>
                        <th>Vardiya</th>
                        <th>Aktif</th>
                        <th>Kayıt Eden</th>
                        <th>Kayıt Tarihi</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </thead>

                <tbody>

                    @{
                        int counter = 1;
                    }

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@counter</td>

                            <td>@item.ReceiptDate.ToString("dd.MM.yyyy")</td>
                            <td>@item.SampleCollectionTime</td>

                            <td>@item.SampleResultDeliveryTime</td>

                            <td>
                                @(string.IsNullOrEmpty(item.SampleTakenLocation)
                                                            ? "-"
                                                            : item.SampleTakenLocation)
                                                                                   </td>

                            <td>@item.DryMatter</td>

                            <td>@item.Filling</td>

                            <td>
                                @(string.IsNullOrEmpty(item.Explanation)
                                                            ? "-"
                                                            : item.Explanation)
                        </td>

                            <td>@item.ShiftName</td>

                            <td>
                            @if (item.InUse == 1)
                                {
                                    <span class="badge bg-success">
                                        Aktif
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Pasif
                                    </span>
                                }
                        </td>
                        <td>
                            @(string.IsNullOrEmpty(item.CreatedByName)
                                                        ? "-"
                                                        : item.CreatedByName)
                        </td>

                            <td>
                                @(item.InsertDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                            </td>



                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning px-2 py-1"
                                        onclick="openModal(@item.RecId)">
                                    <i class="bi bi-pencil-square fs-6"></i>
                                </button>
                            </td>

                            <td class="text-center">

                                <form method="post"
                                      asp-action="Delete"
                                      asp-route-id="@item.RecId"
                                      style="display:inline;">

                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Silinsin mi?');">

                                        <ion-icon name="trash-outline"></ion-icon>

                                    </button>

                                </form>

                            </td>

                        </tr>

                                        counter++;
                    }

                </tbody>

                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Fiş Tarihi</th>
                        <th>Numune Alma Süresi (dk)</th>
                        <th>Sonuç Teslim Süresi (dk)</th>
                        <th>Numune Alınan Yer</th>
                        <th>Kuru Madde (%)</th>
                        <th>Doluluk</th>
                        <th>Açıklama</th>
                        <th>Vardiya</th>
                        <th>Aktif</th>
                        <th>Kayıt Eden</th>
                        <th>Kayıt Tarihi</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </tfoot>

            </table>

        </div>

        <button class="btn btn-primary shadow-sm"
                onclick="openModal()">

            <ion-icon name="add-circle-outline"></ion-icon>

            Yeni Kayıt Ekle

        </button>

    </div>
</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/WaterTreatmentAnalysisResults/Edit/${id}`
            : `/WaterTreatmentAnalysisResults/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('waterTreatmentAnalysisResultsModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/WaterTreatmentAnalysisResults/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>

