@using DTOLayer.Dtos.SentezNotOrdersDtos

@{
    ViewData["Title"] = "GetSentezNotOrdersList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
}

@model IEnumerable<SentezNotOrderDto>

<h6 class="mb-0 text-uppercase">Sentezde Siparişi Olmayanlar</h6>
<hr />

<div class="card">
    <div class="card-body">

        <div class="table-responsive">
            <table id="example2" class="table table-striped table-bordered">

                <thead>
                    <tr>
                        <th>#</th>
                        <th>Fiş Tarihi</th>
                        <th>İrsaliye Tarihi</th>
                        <th>İrsaliye/Fatura No</th>
                        <th>Gelen Firma</th>
                        <th>Sentez Kodu</th>
                        <th>Ürün/Malzeme</th>
                        <th>Ürün Grubu</th>
                        <th>Miktar</th>
                        <th>Birim</th>
                        <th>Depo Giriş Tarihi</th>
                        <th>Bekleme Süresi</th>
                        <th>Açıklama</th>
                        <th>Kullanıcı</th>
                        <th>Vardiya</th>
                        <th>Aktif</th>
                        <th>Kayıt Tarihi</th>
                        <th>Güncelleme</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </thead>

                <tbody>

                    @{
                        int counter = 1;
                    }

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@counter</td>
                            <td>@item.ReceiptDate.ToString("dd.MM.yyyy")</td>

                            <td>
                                @(item.InvoiceDate?.ToString("dd.MM.yyyy") ?? "-")
                            </td>

                            <td>
                                @(item.InvoiceNumber ?? "-")
                            </td>

                            <td>
                                @(item.SupplierCompany ?? "-")
                            </td>

                            <td>
                                @(item.SynthesisCode ?? "-")
                            </td>

                            <td>
                                @(item.ProductMaterial ?? "-")
                            </td>

                            <td>
                                @(item.ProductMaterialGroup ?? "-")
                            </td>

                            <td>
                                @item.Quantity?.ToString("N2")
                            </td>

                            <td>
                                @(item.Unit ?? "-")
                            </td>

                            <td>
                                @(item.WarehouseEntryDate?.ToString("dd.MM.yyyy") ?? "-")
                            </td>

                            <td>
                                @(item.WaitingPeriod?.ToString() ?? "-")
                            </td>

                            <td>
                                @(item.Description ?? "-")
                            </td>

                           

                            <td>
                                @item.CreatedByName
                            </td>

                            <td>
                                @(item.ShiftName ?? "-")    
                            </td>

                            <td>
                                @if (item.InUse == 1)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Pasif</span>
                                }
                            </td>

                            <td>
                                @(item.InsertDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                            </td>

                            <td>
                                @(item.UpdateDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                            </td>

                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning"
                                        onclick="openModal(@item.RecId)">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                            </td>

                            <td class="text-center">
                                <form method="post"
                                      asp-action="Delete"
                                      asp-route-id="@item.RecId"
                                      style="display:inline;">

                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Silinsin mi?');">
                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>

                                </form>
                            </td>

                        </tr>

                        counter++;
                    }

                </tbody>

                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Fiş Tarihi</th>
                        <th>İrs. Tarih</th>
                        <th>İrs/Fatura No</th>
                        <th>Firma</th>
                        <th>Sentez Kodu</th>
                        <th>Ürün</th>
                        <th>Grup</th>
                        <th>Miktar</th>
                        <th>Birim</th>
                        <th>Depo Giriş</th>
                        <th>Bekleme</th>
                        <th>Açıklama</th>
                        <th>Kullanıcı</th>
                        <th>Vardiya</th>
                        <th>Aktif</th>
                        <th>Kayıt</th>
                        <th>Güncelleme</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </tfoot>

            </table>
        </div>

        <button class="btn btn-primary shadow-sm" onclick="openModal()">
            <ion-icon name="add-circle-outline"></ion-icon>
            Yeni Kayıt Ekle
        </button>

    </div>
</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/SentezNotOrders/Edit/${id}`
            : `/SentezNotOrders/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('sentezNotOrdersModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/SentezNotOrders/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>

