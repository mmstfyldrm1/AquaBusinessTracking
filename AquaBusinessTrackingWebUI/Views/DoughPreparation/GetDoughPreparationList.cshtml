@using DTOLayer.Dtos.DoughPreparationDtos.DoughPreparationHeadDtos

@{
    ViewData["Title"] = "GetDoughPreparationList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
    int counter = 1;
}
@model List<DoughPreparationDto>

<h6 class="mb-0 text-uppercase">Pulper Takip Sistemi</h6>
<hr />

<div class="card">
    <div class="card-body">

        <div class="table-responsive">
            <table id="example2" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tarih</th>
                        <th>Pulper No</th>
                        <th>Stok Kodu</th>
                        <th>Stok Adı</th>
                        <th>Sıra No</th>
                        <th>Kırpıntı</th>
                        <th>Balyâ</th>
                        <th>KG</th>
                        <th>Kayıt Tarihi</th>
                        <th>Kayıt Eden</th>
                        <th>Vardiya</th>
                        <th>Güncelleme Tarihi</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </thead>

                <tbody>


                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@counter</td>

                            <td>
                                @item.ReceiptDate.ToString("dd.MM.yyyy")
                            </td>

                            <td>
                                @item.PulperNo
                            </td>

                            <td>
                                @item.InventoryCode
                            </td>

                            <td>
                                @item.InventoryName
                            </td>

                            <td>
                                @item.QueueNo
                            </td>

                            <td>
                                @item.Clippings
                            </td>

                            <td>
                                @item.Bale
                            </td>

                            <td>
                                @item.KG
                            </td>

                            <td>
                                @(item.InsertDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                            </td>
                            <td>
                                @item.CreatedByName
                            </td>
                            <td>
                                @item.ShiftName
                            </td>

                            <td>
                                @(item.UpdateDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                            </td>

                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning px-2 py-1"
                                        onclick="openModal(@item.RecId)">
                                    <i class="bi bi-pencil-square fs-6"></i>
                                </button>
                            </td>

                            <td class="text-center">
                                <form method="post"
                                      asp-action="Delete"
                                      asp-route-id="@item.RecId"
                                      style="display:inline;">

                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Kayıt silinsin mi?');">

                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>

                                </form>
                            </td>

                        </tr>

                        counter++;
                    }

                </tbody>

                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Tarih</th>
                        <th>Pulper No</th>
                        <th>Stok Kodu</th>
                        <th>Stok Adı</th>
                        <th>Sıra No</th>
                        <th>Kırpıntı</th>
                        <th>Balyâ</th>
                        <th>KG</th>
                        <th>Kayıt Tarihi</th>
                        <th>Kayıt Eden</th>
                        <th>Vardiya</th>
                        <th>Güncelleme Tarihi</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </tfoot>
            </table>
        </div>

        <button class="btn btn-primary shadow-sm mt-3"
                onclick="openModal()">

            <ion-icon name="add-circle-outline"></ion-icon>
            Yeni Kayıt Ekle

        </button>

    </div>
</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/DoughPreparation/Edit/${id}`
            : `/DoughPreparation/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('doughPreparationModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/DoughPreparation/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>

