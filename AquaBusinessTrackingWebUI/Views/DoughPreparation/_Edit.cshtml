@using DTOLayer.Dtos.DoughPreparationDtos.DoughPreparationHeadDtos
@model ModalViewModel<DoughPreparationDto>

<div class="modal fade" id="doughPreparationModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">@Model.ModalTitle</h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <form method="post" action="/DoughPreparation/Edit">

                <div class="modal-body">

                    <div class="row g-3">

                        @if (Model.IsEdit)
                        {
                            <input type="hidden" asp-for="Entity.RecId" />
                        }

                        <div class="col-md-4">
                            <label class="form-label">Tarih</label>

                            <input type="date"
                                   asp-for="Entity.ReceiptDate"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Pulper No</label>

                            <input type="text"
                                   asp-for="Entity.PulperNo"
                                   class="form-control"
                                   placeholder="Örn: Pulper-1" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Sıra No</label>

                            <input type="number"
                                   step="0.01"
                                   asp-for="Entity.QueueNo"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Stok Kodu</label>

                            <input type="text"
                                   asp-for="Entity.InventoryCode"
                                   class="form-control"
                                   placeholder="Stok kodu giriniz" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Stok Adı</label>

                            <input type="text"
                                   asp-for="Entity.InventoryName"
                                   class="form-control"
                                   placeholder="Stok adı giriniz" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Kırpıntı</label>

                            <div class="input-group">
                                <input type="number"
                                       step="0.01"
                                       asp-for="Entity.Clippings"
                                       class="form-control" />

                                <span class="input-group-text">KG</span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Balyâ</label>

                            <div class="input-group">
                                <input type="number"
                                       step="0.01"
                                       asp-for="Entity.Bale"
                                       class="form-control" />

                                <span class="input-group-text">KG</span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Toplam KG</label>

                            <div class="input-group">
                                <input type="number"
                                       step="0.01"
                                       asp-for="Entity.KG"
                                       class="form-control" />

                                <span class="input-group-text">KG</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Vardiya</label>

                            <select asp-for="Entity.ShiftId"
                                    asp-items="ViewBag.Shifts"
                                    class="form-select">

                                <option value="">Vardiya Seçiniz</option>

                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Kayıt Eden</label>

                            <div class="input-group">

                                <span class="input-group-text">
                                    <ion-icon name="person-outline"></ion-icon>
                                </span>

                                <input type="text"
                                       class="form-control"
                                       value="@ViewBag.AppUserName"
                                       disabled />

                            </div>
                        </div>

                        <input type="hidden" asp-for="Entity.DepartmentId" />
                        <input type="hidden" asp-for="Entity.AppUserId" />
                        <input type="hidden" asp-for="Entity.InsertDate" />
                        <input type="hidden" asp-for="Entity.UpdateDate" />
                        <input type="hidden" asp-for="Entity.InUse" />

                    </div>

                </div>

                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-light"
                            data-bs-dismiss="modal">

                        İptal

                    </button>

                    <button type="submit"
                            class="btn btn-success px-4">

                        <ion-icon name="save-outline" class="me-1"></ion-icon>

                        @(Model.IsEdit ? "Güncelle" : "Kaydet")

                    </button>

                </div>

            </form>

        </div>
    </div>
</div>