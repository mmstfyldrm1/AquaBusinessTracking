@using DTOLayer.Dtos.PlcDtos.PlcTagsDtos

@{
    ViewData["Title"] = "GetMachineTagsList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
}

@model List<PlcMachineTagsDto>

<h6 class="mb-0 text-uppercase">PLC Makine Tag Listesi</h6>
<hr />

<div class="card">
    <div class="card-body">
        <div class="table-responsive">

            <table id="example2" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Makine Adı</th>
                        <th>Tag Adı</th>
                        <th>Görünen Ad</th>
                        <th>Unit</th>
                        <th>Group</th>
                        <th>Data Address</th>
                        <th>Data Type</th>
                        <th>Durum</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </thead>

                <tbody>
                    @{
                        int counter = 1;
                    }

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@counter</td>

                            <td>@item.MachineName</td>

                            <td>@item.TagName</td>

                            <td>
                                @(!string.IsNullOrEmpty(item.DisplayName) ? item.DisplayName : "-")
                            </td>

                            <td>@item.Unit</td>

                            <td>@item.Group</td>

                            <td>@item.DataAddress</td>

                            <td>@item.DataType</td>

                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Pasif</span>
                                }
                            </td>

                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning"
                                        onclick="openModal(@item.RecId)">
                                    ✏️
                                </button>
                            </td>

                            <td class="text-center">
                                <form method="post"
                                      asp-action="Delete"
                                      asp-route-id="@item.RecId"
                                      onsubmit="return confirm('Silinsin mi?');">
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        🗑
                                    </button>
                                </form>
                            </td>
                        </tr>

                        counter++;
                    }
                </tbody>

                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Makine Adı</th>
                        <th>Tag Adı</th>
                        <th>Görünen Ad</th>
                        <th>Unit</th>
                        <th>Group</th>
                        <th>Data Address</th>
                        <th>Data Type</th>
                        <th>Durum</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </tfoot>

            </table>

        </div>

        <button class="btn btn-primary" onclick="openModal()">
            ➕ Yeni Tag Ekle
        </button>

    </div>
</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/PlcMachineTags/Edit/${id}`
            : `/PlcMachineTags/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('PlcTagModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/PlcMachineTags/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>

