@using System.Globalization
@using DTOLayer.Dtos.UserDtos
@model UpdateUserDto
@{
    ViewData["Title"] = "UserProfile";
    Layout = "~/Views/_UserLayout/Index.cshtml";
    var userName = User.Identity?.Name ?? "Kullanıcı";
    var today = DateTime.Now.ToString("dd MMMM yyyy", new CultureInfo("tr-TR"));
}



<div class="row">

    <div class="col-lg-4">
        <div class="card radius-10">
            <div class="card-body text-center">
                <div class="mb-3 position-relative d-inline-block">
                    <img src="@Model.CoverImgUrl" class="rounded-circle border" width="120" height="120" alt="profil fotoğrafı">
                    <label for="avatarUpload" class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width:34px;height:34px;cursor:pointer;">
                        <ion-icon name="camera-outline"></ion-icon>
                    </label>
                    <input type="file" id="avatarUpload" class="d-none" accept="image/*">
                </div>
                <h5 class="mb-1">@Model.Name</h5>
                <p class="text-secondary mb-3">MES Yönetim Sistemi</p>
                <div class="d-flex justify-content-center gap-2">
                    <button type="button"  class="btn btn-sm btn-outline-primary">Fotoğrafı Değiştir</button>
                    <button type="button" class="btn btn-sm btn-outline-danger">Kaldır</button>
                </div>
                <hr class="my-4">
                <div class="row text-start g-3">
                    <div class="col-12 d-flex align-items-center gap-2">
                        <ion-icon name="mail-outline" class="text-secondary"></ion-icon>
                        <span class="small">@Model.Email</span>
                    </div>
                    <div class="col-12 d-flex align-items-center gap-2">
                        <ion-icon name="call-outline" class="text-secondary"></ion-icon>
                        <span class="small">@Model.PhoneNumber</span>
                    </div>
                    <div class="col-12 d-flex align-items-center gap-2">
                        <ion-icon name="business-outline" class="text-secondary"></ion-icon>
                        <span class="small">@Model.DepartmentName</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- şifre değiştir -->
        <div class="card radius-10">
            <div class="card-body">
                <h6 class="mb-3">Şifre Değiştir</h6>
                <form>
                    <div class="mb-3">
                        <label class="form-label">Mevcut Şifre</label>
                        <input type="password" class="form-control" placeholder="••••••••">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Yeni Şifre</label>
                        <input type="password" class="form-control" placeholder="••••••••">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Yeni Şifre (Tekrar)</label>
                        <input type="password" class="form-control" placeholder="••••••••">
                    </div>
                    <button type="submit" class="btn btn-outline-primary w-100">Şifreyi Güncelle</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card radius-10">
            <div class="card-body">
                <h6 class="mb-3">Kişisel Bilgiler</h6>
                <form>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Ad</label>
                            <input type="text" class="form-control" placeholder="@Model.Name" asp-for="@Model.Name">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Soyad</label>
                            <input type="text" class="form-control" placeholder="@Model.SurName" asp-for="@Model.SurName">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Kullanıcı Adı</label>
                            <input type="text" class="form-control" placeholder="@Model.UserName" asp-for="@Model.UserName">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">E-Posta</label>
                            <input type="email" class="form-control" placeholder="@Model.Email" asp-for="@Model.Email">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Telefon</label>
                            <input type="text" class="form-control" placeholder="@Model.PhoneNumber" asp-for="@Model.PhoneNumber">
                        </div>
                        @* <div class="col-12">
                            <label class="form-label">Hakkında</label>
                            <textarea class="form-control" rows="3" placeholder="Kısa bir açıklama yazın...">MES sisteminde üretim hattı takibi ve raporlama üzerinde çalışıyorum.</textarea>
                        </div> *@
                    </div>
                </form>
            </div>
        </div>

        <!-- bildirim ve tercihler -->
        <div class="card radius-10">
            <div class="card-body">
                <h6 class="mb-3">Bildirim Tercihleri</h6>
                <div class="row g-3">
                    <div class="col-md-6 d-flex align-items-center justify-content-between border rounded-3 p-3">
                        <div>
                            <p class="mb-0 fw-500">E-Posta Bildirimleri</p>
                            <small class="text-secondary">Vardiya ve arıza uyarıları</small>
                        </div>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" role="switch" checked>
                        </div>
                    </div>
                    <div class="col-md-6 d-flex align-items-center justify-content-between border rounded-3 p-3">
                        <div>
                            <p class="mb-0 fw-500">SMS Bildirimleri</p>
                            <small class="text-secondary">Kritik durum uyarıları</small>
                        </div>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" role="switch">
                        </div>
                    </div>
                    <div class="col-md-6 d-flex align-items-center justify-content-between border rounded-3 p-3">
                        <div>
                            <p class="mb-0 fw-500">Haftalık Rapor</p>
                            <small class="text-secondary">Üretim özet raporu</small>
                        </div>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" role="switch" checked>
                        </div>
                    </div>
                    <div class="col-md-6 d-flex align-items-center justify-content-between border rounded-3 p-3">
                        <div>
                            <p class="mb-0 fw-500">Karanlık Mod</p>
                            <small class="text-secondary">Arayüz teması</small>
                        </div>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" role="switch">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- kaydet / iptal -->
        <div class="d-flex justify-content-end gap-2">
            <button type="button" class="btn btn-outline-secondary">İptal</button>
            <button type="button" class="btn btn-primary">Değişiklikleri Kaydet</button>
        </div>
    </div>
</div>