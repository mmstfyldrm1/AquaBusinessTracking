@using System.Globalization
@using DTOLayer.Dtos.UserDtos
@model UserProfileViewModel
@{
    ViewData["Title"] = "UserProfile";
    Layout = "~/Views/_UserLayout/Index.cshtml";
    var userName = User.Identity?.Name ?? "Kullanıcı";
    var today = DateTime.Now.ToString("dd MMMM yyyy", new CultureInfo("tr-TR"));
    var hasAvatar = !string.IsNullOrWhiteSpace(Model.UpdateUser.CoverImgUrl);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">Profilim</h4>
        <span class="text-secondary small">@today</span>
    </div>
</div>

<form asp-action="UserProfile"
      asp-controller="UserProfile"
      method="post"
      enctype="multipart/form-data">

    <input asp-for="UpdateUser.Id" type="hidden" />

    <div class="row g-4">

        <!-- Sol Kolon: Profil Kartı -->
        <div class="col-lg-4">
            <div class="card radius-10 h-100">
                <div class="card-body text-center">

                    <div class="mb-3 position-relative d-inline-block">
                        @if (hasAvatar)
                        {
                            <img src="@Model.UpdateUser.CoverImgUrl"
                                 class="rounded-circle border object-fit-cover"
                                 style="width:120px;height:120px;object-fit:cover;"
                                 alt="profil fotoğrafı">
                        }
                        else
                        {
                            <div class="rounded-circle border bg-light d-flex align-items-center justify-content-center mx-auto"
                                 style="width:120px;height:120px;">
                                <ion-icon name="person-outline" style="font-size:48px;" class="text-secondary"></ion-icon>
                            </div>
                        }
                    </div>

                    <h5 class="mb-1">@Model.UpdateUser.Name @Model.UpdateUser.SurName</h5>
                    <p class="text-secondary mb-3">MES Yönetim Sistemi</p>

                    <div class="d-flex justify-content-center gap-2 mb-2">
                        <label class="btn btn-sm btn-outline-primary mb-0">
                            Fotoğrafı Değiştir
                            <input asp-for="UpdateUser.ProfileImage" type="file" accept="image/*" class="d-none" onchange="this.form.submit ? null : null">
                        </label>
                        <button type="button" class="btn btn-sm btn-outline-danger">Kaldır</button>
                    </div>

                    <hr class="my-4">

                    <div class="row text-start g-3">
                        <div class="col-12 d-flex align-items-center gap-2">
                            <ion-icon name="mail-outline" class="text-secondary"></ion-icon>
                            <span class="small text-truncate">@Model.UpdateUser.Email</span>
                        </div>
                        <div class="col-12 d-flex align-items-center gap-2">
                            <ion-icon name="call-outline" class="text-secondary"></ion-icon>
                            <span class="small">@Model.UpdateUser.PhoneNumber</span>
                        </div>
                        <div class="col-12 d-flex align-items-center gap-2">
                            <ion-icon name="business-outline" class="text-secondary"></ion-icon>
                            <span class="small">@Model.UpdateUser.DepartmentName</span>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Sağ Kolon: Bilgi Formu -->
        <div class="col-lg-8">
            <div class="card radius-10 mb-4">
                <div class="card-body">
                    <h6 class="mb-3 d-flex align-items-center gap-2">
                        <ion-icon name="person-circle-outline"></ion-icon>
                        Kişisel Bilgiler
                    </h6>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Ad</label>
                            <input asp-for="UpdateUser.Name" class="form-control">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Soyad</label>
                            <input asp-for="UpdateUser.SurName" class="form-control">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Kullanıcı Adı</label>
                            <input asp-for="UpdateUser.UserName" class="form-control">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">E-Posta</label>
                            <input asp-for="UpdateUser.Email" type="email" class="form-control">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Telefon</label>
                            <input asp-for="UpdateUser.PhoneNumber" class="form-control">
                        </div>
                    </div>
                </div>
            </div>

            <div class="card radius-10">
                <div class="card-body">
                    <h6 class="mb-3 d-flex align-items-center gap-2">
                        <ion-icon name="lock-closed-outline"></ion-icon>
                        Şifre Değiştir
                    </h6>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Mevcut Şifre</label>
                            <input asp-for="Password.OldPassword" type="password" class="form-control">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Yeni Şifre</label>
                            <input asp-for="Password.NewPassword" type="password" class="form-control">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Yeni Şifre Tekrar</label>
                            <input asp-for="Password.ConfirmPassword" type="password" class="form-control">
                        </div>
                    </div>

                    <div class="mt-4 text-end">
                        <button type="submit" class="btn btn-primary px-4">
                            <ion-icon name="save-outline" class="me-1"></ion-icon>
                            Kaydet
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</form>
