        <a href="#ozet">Genel Özet</a>
        <a href="#hammadde">Hammadde & Kimyasal</a>
        <a href="#enerji">Enerji & Su</a>
        <a href="#durus">Duruş Analizi</a>
        <a href="#stok">Stok & Üretim</a>
        <a href="#sevk">Sevkiyat & Satış</a>
    </div>

    <div class="content">

        <!-- ÖZET -->
        @await Component.InvokeAsync("_AdminLayoutSummaryComponentPartial")

        <!-- HAMMADDE -->
