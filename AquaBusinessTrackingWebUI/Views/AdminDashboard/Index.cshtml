    Layout = "~/Views/_UserLayout/Index.cshtml";
}

<!DOCTYPE html>
<html lang="tr">

    @await Component.InvokeAsync("_AdminLayoutHeadComponentPartial")
<body>

    @await Component.InvokeAsync("_AdminLayoutStatisticComponentPartial")


    <!-- TOP NAV -->
