        <!-- ENERJİ -->
        @await Component.InvokeAsync("_AdminLayoutEnergyComponentPartial")


        <!-- DURUŞ -->
        @await Component.InvokeAsync("_AdminLayoutStanceComponentPartial")
       

        <!-- STOK -->
