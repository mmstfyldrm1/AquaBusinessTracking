@using DTOLayer.Dtos.SalesScale
@using AquaBusinessTrackingWebUI.Models
@model ModalViewModel<SalesScaleDto>

<div class="modal fade" id="salesScaleModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">@Model.ModalTitle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" action="/SalesScale/Edit">
                <div class="modal-body">

                    <input type="hidden" name="IsEdit" value="@Model.IsEdit.ToString().ToLower()" />

                    @if (Model.IsEdit)
                    {
                        <input type="hidden" asp-for="Entity.RecId" />
                    }

                    <div class="row g-3">

                        <div class="col-md-4">
                            <label class="form-label">Tartım No</label>
                            <input type="number" asp-for="Entity.ScaleNo" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Tarih</label>
                            <input type="date" asp-for="Entity.ReceiptDate" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Saat</label>
                            <input type="time" asp-for="Entity.ScaleHours" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">İrsaliye No</label>
                            <input type="text" asp-for="Entity.DeliveryNumber" class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Cari Adı</label>
                            <input type="text" asp-for="Entity.CurrentAccountName" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Araç Plaka</label>
                            <input type="text" asp-for="Entity.TruckPlate" class="form-control" placeholder="34 ABC 123" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Sevkiyat Miktar</label>
                            <input type="number" step="0.01" asp-for="Entity.DeliveryQuantity" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Kantar Miktar</label>
                            <input type="number" step="0.01" asp-for="Entity.ScaleQuantity" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Fark</label>
                            <input type="number" asp-for="Entity.ScaleGap" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Sorumlu</label>
                            <input type="text" asp-for="Entity.GapSuperVisior" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Karar</label>
                            <input type="text" asp-for="Entity.GapDesicion" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Vardiya</label>
                            <select asp-for="Entity.ShiftId" asp-items="ViewBag.Shifts" class="form-select">
                                <option value="">Vardiya Seçiniz</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Kayıt Eden</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <ion-icon name="person-outline"></ion-icon>
                                </span>
                                <input type="text" class="form-control" value="@ViewBag.AppUserName" disabled />
                            </div>
                        </div>

                        <input type="hidden" asp-for="Entity.DepartmentId" />
                        <input type="hidden" asp-for="Entity.AppUserId" />
                        <input type="hidden" asp-for="Entity.InsertDate" />

                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-success px-4">
                        <ion-icon name="save-outline" class="me-1"></ion-icon>
                        @(Model.IsEdit ? "Güncelle" : "Kaydet")
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>