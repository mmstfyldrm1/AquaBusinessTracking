@using DTOLayer.Dtos.LogisticsTrackingReportDtos

@{
    ViewData["Title"] = "GetLogisticsTrackingReportList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
}

@model IEnumerable<LogisticsTrackingReportDto>

<h6 class="mb-0 text-uppercase">Lojistik Nakliye Raporu</h6>
<hr />

<div class="card">
    <div class="card-body">

        <div class="table-responsive">
            <table id="example2" class="table table-striped table-bordered">

                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tarih</th>
                        <th>Nakliye Firması</th>
                        <th>Çıkış Yeri</th>
                        <th>Varış Yeri</th>
                        <th>Araç</th>
                        <th>Soför/Plaka</th>
                        <th>Fiyat</th>
                        <th>İşlem Yapılan Firma</th>
                        <th>Durum</th>
                        <th>Fatura No</th>
                        <th>Bölüm</th>
                        <th>Vardiya</th>
                        <th>Kayıt Tarihi</th>
                        <th>Güncelleme</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </thead>

                <tbody>

                    @{
                        int counter = 1;
                    }

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@counter</td>

                            <td>
                                @(item.ReceiptDate.ToString("dd.MM.yyyy") ?? "-")
                            </td>

                            <td>
                                @(item.CarrierCompany ?? "-")
                            </td>

                            <td>
                                @(item.DepartureLocation ?? "-")
                            </td>

                            <td>
                                @(item.ArrivalLocation ?? "-")
                            </td>

                            <td>
                                @(item.Vehicle ?? "-")
                            </td>

                            <td>
                                @(item.DriverNameOrPlate ?? "-")
                            </td>

                            <td>
                                @(item.Price?.ToString("N2") ?? "-")
                            </td>

                            <td>
                                @(item.ProcessingCompany ?? "-")
                            </td>

                            <td>
                                <span class="badge bg-info">
                                    @(item.Status ?? "-")
                                </span>
                            </td>

                            <td>
                                @(item.InvoiceNumber ?? "-")
                            </td>

                            <td>
                                @item.CreatedByName
                            </td>

                            <td>
                                @item.ShiftName
                            </td>

                            <td>
                                @(item.InsertDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                            </td>

                            <td>
                                @(item.UpdateDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                            </td>

                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-warning"
                                        onclick="openModal(@item.RecId)">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                            </td>

                            <td class="text-center">
                                <form method="post"
                                      asp-action="Delete"
                                      asp-route-id="@item.RecId"
                                      style="display:inline;">

                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Silinsin mi?');">
                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>

                                </form>
                            </td>

                        </tr>

                        counter++;
                    }

                </tbody>

                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Tarih</th>
                        <th>Nakliye Firması</th>
                        <th>Çıkış Yeri</th>
                        <th>Varış Yeri</th>
                        <th>Araç</th>
                        <th>Soför/Plaka</th>
                        <th>Fiyat</th>
                        <th>İşlem Yapılan</th>
                        <th>Durum</th>
                        <th>Fatura No</th>
                        <th>Kullanıcı</th>
                        <th>Vardiya</th>
                        <th>Kayıt</th>
                        <th>Güncelleme</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </tfoot>

            </table>
        </div>

        <button class="btn btn-primary shadow-sm" onclick="openModal()">
            <ion-icon name="add-circle-outline"></ion-icon>
            Yeni Kayıt Ekle
        </button>

    </div>
</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/LogisticsTrackingReport/Edit/${id}`
            : `/LogisticsTrackingReport/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('logisticsTrackingReportModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/LogisticsTrackingReport/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>
