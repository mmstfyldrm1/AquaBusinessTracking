@using DTOLayer.Dtos.LogisticsTrackingReportDtos
@model ModalViewModel<LogisticsTrackingReportDto>

<div class="modal fade" id="logisticsTrackingReportModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">@Model.ModalTitle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" action="/LogisticsTrackingReport/Edit">
                <div class="modal-body">

                    <input type="hidden" name="IsEdit" value="@Model.IsEdit.ToString().ToLower()" />

                    @if (Model.IsEdit)
                    {
                        <input type="hidden" asp-for="Entity.RecId" />
                    }

                    <input type="hidden" asp-for="Entity.DepartmentId" />
                    <input type="hidden" asp-for="Entity.AppUserId" />
                    <input type="hidden" asp-for="Entity.InsertDate" />

                    <!-- Genel Bilgiler -->
                    <h6 class="fw-bold text-muted mb-3">Nakliye Bilgileri</h6>

                    <div class="row g-3 mb-4">

                        <div class="col-md-4">
                            <label class="form-label">Tarih</label>
                            <input type="date"
                                   asp-for="Entity.ReceiptDate"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Nakliye Firması</label>
                            <input type="text"
                                   asp-for="Entity.CarrierCompany"
                                   class="form-control"
                                   placeholder="Nakliye firması giriniz" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Fatura No</label>
                            <input type="text"
                                   asp-for="Entity.InvoiceNumber"
                                   class="form-control"
                                   placeholder="Fatura no giriniz" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Çıkış Yeri</label>
                            <input type="text"
                                   asp-for="Entity.DepartureLocation"
                                   class="form-control"
                                   placeholder="Çıkış yeri giriniz" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Varış Yeri</label>
                            <input type="text"
                                   asp-for="Entity.ArrivalLocation"
                                   class="form-control"
                                   placeholder="Varış yeri giriniz" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Araç</label>
                            <input type="text"
                                   asp-for="Entity.Vehicle"
                                   class="form-control"
                                   placeholder="Araç bilgisi giriniz" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Soför/Plaka</label>
                            <input type="text"
                                   asp-for="Entity.DriverNameOrPlate"
                                   class="form-control"
                                   placeholder="Soför ismi veya plaka giriniz" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Fiyat</label>
                            <input type="number"
                                   step="0.01"
                                   asp-for="Entity.Price"
                                   class="form-control"
                                   placeholder="Fiyat giriniz" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Vardiya</label>
                            <select asp-for="Entity.ShiftId"
                                    asp-items="ViewBag.Shifts"
                                    class="form-select">
                                <option value="">Vardiya Seçiniz</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">İşlem Yapılan Firma</label>
                            <input type="text"
                                   asp-for="Entity.ProcessingCompany"
                                   class="form-control"
                                   placeholder="İşlem yapılan firma giriniz" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Durum</label>
                            <input type="text"
                                   asp-for="Entity.Status"
                                   class="form-control"
                                   placeholder="Durum giriniz" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Kayıt Eden</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <ion-icon name="person-outline"></ion-icon>
                                </span>
                                <input type="text"
                                       class="form-control"
                                       value="@ViewBag.AppUserName"
                                       disabled />
                            </div>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">Açıklama</label>
                            <textarea asp-for="Entity.Description"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Açıklama giriniz">
                            </textarea>
                        </div>

                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-light"
                            data-bs-dismiss="modal">
                        İptal
                    </button>

                    <button type="submit"
                            class="btn btn-success px-4">
                        <ion-icon name="save-outline" class="me-1"></ion-icon>
                        @(Model.IsEdit ? "Güncelle" : "Kaydet")
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>