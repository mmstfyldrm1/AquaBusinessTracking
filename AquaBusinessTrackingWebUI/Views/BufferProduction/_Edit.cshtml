@using DTOLayer.Dtos.BufferProductionDtos
@model ModalViewModel<BufferProductionDto>

<div class="modal fade" id="bufferProductionModal" tabindex="-1">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">@Model.ModalTitle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <form method="post" action="/BufferProduction/Edit">

                    <div class="modal-body">

                        <div class="row g-3">

                            @if (Model.IsEdit)
                            {
                                <input type="hidden" asp-for="Entity.RecId" />
                            }

                            <!-- SHIFT SUPERVISOR -->
                        <div class="col-md-4">
                        <label class="form-label">Vardiya Amiri</label>
                            <select asp-for="Entity.ShiftSupervisorUserId"
                                asp-items="ViewBag.Users"
                                class="form-select">
                            <option value="">Personel Seçiniz</option>
                        </select>
                        </div>


                            <!-- PRODUCT -->
                            <div class="col-md-4">
                                <label class="form-label">Ürün</label>
                                <input type="text"
                                       asp-for="Entity.Product"
                                       class="form-control" />
                            </div>

                            <!-- GR/M2 -->
                            <div class="col-md-4">
                                <label class="form-label">Gr/m²</label>
                                <input type="number"
                                       step="0.01"
                                       asp-for="Entity.GrPerM2"
                                       class="form-control" />
                            </div>

                            <!-- BUFFER NO -->
                            <div class="col-md-4">
                                <label class="form-label">Tampon No</label>
                                <input type="number"
                                       asp-for="Entity.BufferNo"
                                       class="form-control" />
                            </div>

                            <!-- START -->
                            <div class="col-md-4">
                                <label class="form-label">Başlangıç</label>
                                <input type="datetime-local"
                                       asp-for="Entity.BufferStart"
                                       class="form-control" />
                            </div>

                            <!-- END -->
                            <div class="col-md-4">
                                <label class="form-label">Bitiş</label>
                                <input type="datetime-local"
                                       asp-for="Entity.BufferEnd"
                                       class="form-control" />
                            </div>

                            <!-- TOTAL TIME -->
                            <div class="col-md-4">
                                <label class="form-label">Toplam Süre (dk)</label>
                                <input type="number"
                                       asp-for="Entity.TotalDurationMinutes"
                                       class="form-control" />
                            </div>

                            <!-- DOWNTIME -->
                            <div class="col-md-4">
                                <label class="form-label">Duruş Süresi (dk)</label>
                                <input type="number"
                                       asp-for="Entity.DowntimeMinutes"
                                       class="form-control" />
                            </div>

                            <!-- SPEED -->
                            <div class="col-md-4">
                                <label class="form-label">Hız (m/dk)</label>
                                <input type="number"
                                       step="0.01"
                                       asp-for="Entity.BufferSpeed"
                                       class="form-control" />
                            </div>

                            <!-- WIDTH -->
                            <div class="col-md-4">
                                <label class="form-label">Genişlik (cm)</label>
                                <input type="number"
                                       step="0.01"
                                       asp-for="Entity.BufferWidthCm"
                                       class="form-control" />
                            </div>

                            <!-- SET COUNT -->
                            <div class="col-md-4">
                                <label class="form-label">Set Sayısı</label>
                                <input type="number"
                                       asp-for="Entity.BufferSetCount"
                                       class="form-control" />
                            </div>

                            <!-- THEORETICAL KG -->
                            <div class="col-md-6">
                                <label class="form-label">Teorik Kg</label>
                                <input type="number"
                                       step="0.01"
                                       asp-for="Entity.TheoreticalBufferKg"
                                       class="form-control" />
                            </div>

                            <!-- MEASURED KG -->
                            <div class="col-md-6">
                                <label class="form-label">Ölçülen Kg</label>
                                <input type="number"
                                       step="0.01"
                                       asp-for="Entity.MeasuredKg"
                                       class="form-control" />
                            </div>

                            <!-- DESCRIPTION -->
                            <div class="col-md-12">
                                <label class="form-label">Açıklama</label>
                                <textarea asp-for="Entity.Description"
                                          class="form-control"
                                          rows="2"></textarea>
                            </div>

                            <!-- SHIFT -->
                            <div class="col-md-6">
                                <label class="form-label">Vardiya</label>
                                <select asp-for="Entity.ShiftId"
                                        asp-items="ViewBag.Shifts"
                                        class="form-select">
                                    <option value="">Vardiya Seçiniz</option>
                                </select>
                            </div>

                            <!-- USER -->
                            <div class="col-md-6">
                                <label class="form-label">Kayıt Eden</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <ion-icon name="person-outline"></ion-icon>
                                    </span>
                                    <input type="text"
                                           class="form-control"
                                           value="@ViewBag.AppUserName"
                                           disabled />
                                </div>
                            </div>

                            <!-- SYSTEM FIELDS -->
                            <input type="hidden" asp-for="Entity.DepartmentId" />
                            <input type="hidden" asp-for="Entity.AppUserId" />
                            <input type="hidden" asp-for="Entity.InsertDate" />
                            <input type="hidden" asp-for="Entity.UpdateDate" />
                            <input type="hidden" asp-for="Entity.DeleteDate" />
                            <input type="hidden" asp-for="Entity.InUse" />
                            <input type="hidden" asp-for="Entity.DeletedBy" />
                            <input type="hidden" asp-for="Entity.UpdatedBy" />

                        </div>

                    </div>

                    <div class="modal-footer">

                        <button type="button"
                                class="btn btn-light"
                                data-bs-dismiss="modal">
                            İptal
                        </button>

                        <button type="submit"
                                class="btn btn-success px-4">
                            <ion-icon name="save-outline" class="me-1"></ion-icon>
                            @(Model.IsEdit ? "Güncelle" : "Kaydet")
                        </button>

                    </div>

                </form>

            </div>
        </div>
    </div>
