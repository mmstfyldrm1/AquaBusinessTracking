@using DTOLayer.Dtos.CirculationTankAirPressureMeasurementTurbidity
@model ModalViewModel<CirculationTankAirPressureMeasurementTurbidityDto>

<div class="modal fade" id="circulationTankModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">@Model.ModalTitle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" action="/CirculationTankAirPressureMeasurementTurbidity/Edit">

                <div class="modal-body">

                    <div class="row g-3">

                        @if (Model.IsEdit)
                        {
                            <input type="hidden" asp-for="Entity.RecId" />
                        }

                        <div class="col-md-4">
                            <label class="form-label">Tarih</label>
                            <input type="date"
                                   asp-for="Entity.ReceiptDate"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Saat</label>
                            <input type="time"
                                   asp-for="Entity.Time"
                                   class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Makine Hızı</label>
                            <div class="input-group">
                                <input type="number"
                                       step="0.01"
                                       asp-for="Entity.MachineSpeed"
                                       class="form-control" />
                                <span class="input-group-text">m/dk</span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Üretim Tipi</label>
                            <input type="text"
                                   asp-for="Entity.ProductionType"
                                   class="form-control"
                                   placeholder="Üretim tipi giriniz" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Gramaj</label>
                            <div class="input-group">
                                <input type="number"
                                       step="0.01"
                                       asp-for="Entity.Grammage"
                                       class="form-control" />
                                <span class="input-group-text">g/m²</span>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Tur Sayısı</label>
                            <input type="number"
                                   asp-for="Entity.TurnCount"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">FAU</label>
                            <input type="number"
                                   step="0.01"
                                   asp-for="Entity.Fau"
                                   class="form-control"
                                   placeholder="FAU değeri giriniz" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">NTU</label>
                            <input type="number"
                                   step="0.01"
                                   asp-for="Entity.Ntu"
                                   class="form-control"
                                   placeholder="NTU değeri giriniz" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Vardiya</label>
                            <select asp-for="Entity.ShiftId"
                                    asp-items="ViewBag.Shifts"
                                    class="form-select">
                                <option value="">Vardiya Seçiniz</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Kayıt Eden</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <ion-icon name="person-outline"></ion-icon>
                                </span>
                                <input type="text"
                                       class="form-control"
                                       value="@ViewBag.AppUserName"
                                       disabled />
                            </div>
                        </div>

                        <input type="hidden" asp-for="Entity.DepartmentId" />
                        <input type="hidden" asp-for="Entity.AppUserId" />
                        <input type="hidden" asp-for="Entity.InsertDate" />
                        <input type="hidden" asp-for="Entity.UpdateDate" />
                        <input type="hidden" asp-for="Entity.InUse" />

                    </div>

                </div>

                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-light"
                            data-bs-dismiss="modal">
                        İptal
                    </button>

                    <button type="submit"
                            class="btn btn-success px-4">
                        <ion-icon name="save-outline" class="me-1"></ion-icon>
                        @(Model.IsEdit ? "Güncelle" : "Kaydet")
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>