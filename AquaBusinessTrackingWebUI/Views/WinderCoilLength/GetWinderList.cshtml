@using DTOLayer.Dtos.WinderCoilLengthControlDto

@{
    ViewData["Title"] = "GetWinderList";
    Layout = "~/Views/_UserLayout/Index.cshtml";
    int counter = 0;
}
@model List<WinderCoilLengthControlDto>
<h6 class="mb-0 text-uppercase">Bobin Takip Sistemi</h6>
<hr />

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table id="example2" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Bobin Genişliği</th>
                        <th>Sarıcı Bobin Boyu</th>
                        <th>Gramaj</th>
                        <th>Ağırlık</th>
                        <th>Teorik Bobin Boyu</th>
                        <th>Boy Farkı</th>
                        <th>Sapma</th>
                        <th>Kayıt Tarihi</th>
                        <th>Güncelleme Tarihi</th>
                        <th>Kayıt Eden</th>
                        <th>Vardiya</th>
                        <th>Durum</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@counter</td>

                            <td>@item.CoilWidth</td>

                            <td>@item.WinderCoilLength</td>

                            <td>@item.Gramaj</td>

                            <td>@item.Weight</td>

                            <td>@item.TheoreticCoilLength</td>

                            <td>@item.CoilLengthDifference</td>

                            <td>
                                @{
                                    string badgeClass = "bg-success";

                                    if (Math.Abs(item.CoilLengthDeflection) > 10)
                                    {
                                        badgeClass = "bg-danger";
                                    }
                                    else if (Math.Abs(item.CoilLengthDeflection) > 5)
                                    {
                                        badgeClass = "bg-warning";
                                    }
                                }

                                <span class="badge @badgeClass">
                                    @item.CoilLengthDeflection %
                                </span>
                            </td>

                            <td>
                                @(item.InsertDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                            </td>

                            <td>
                                @(item.UpdateDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                            </td>

                            <td>@item.CreatedByName</td>

                            <td>@item.ShiftName</td>

                            <td>
                                @if (item.InUse == 1)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Pasif</span>
                                }
                            </td>

                            <td class="text-center">

                                <button class="btn btn-sm btn-outline-warning px-2 py-1"
                                        onclick="openModal(@item.RecId)">
                                    <i class="bi bi-pencil-square fs-6"></i>
                                </button>

                            </td>

                            <td class="text-center">

                                <form method="post"
                                      asp-action="DeleteCoil"
                                      asp-route-id="@item.RecId"
                                      style="display:inline;">

                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="return confirm('Kayıt silinsin mi?');">

                                        <ion-icon name="trash-outline"></ion-icon>

                                    </button>

                                </form>

                            </td>

                        </tr>

                        counter++;
                    }

                </tbody>

                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Bobin Genişliği</th>
                        <th>Sarıcı Bobin Boyu</th>
                        <th>Gramaj</th>
                        <th>Ağırlık</th>
                        <th>Teorik Bobin Boyu</th>
                        <th>Boy Farkı</th>
                        <th>Sapma</th>
                        <th>Kayıt Tarihi</th>
                        <th>Güncelleme Tarihi</th>
                        <th>Kayıt Eden</th>
                        <th>Vardiya</th>
                        <th>Durum</th>
                        <th>Güncelle</th>
                        <th>Sil</th>
                    </tr>
                </tfoot>

            </table>
        </div>

        <button class="btn btn-primary shadow-sm" onclick="openModal()">
            <ion-icon name="add-circle-outline"></ion-icon>
            Yeni Bobin Ekle
        </button>

    </div>
</div>

<div id="modalContainer"></div>

<script>
           function openModal(id = null) {
        const url = id
            ? `/WinderCoilLength/Edit/${id}`
            : `/WinderCoilLength/Edit`;

        fetch(url)
            .then(r => r.text())
            .then(html => {
                document.getElementById('modalContainer').innerHTML = html;
                const modalEl = document.getElementById('coilControlModal');
                const modal = new bootstrap.Modal(modalEl);

                modal.show();

                const form = modalEl.querySelector('form');
                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    fetch('/WinderCoilLength/Edit', {
                        method: 'POST',
                        body: new FormData(this)
                    })
                    .then(r => {
                        if (r.ok) {
                            modal.hide();
                            location.reload();
                        }
                    });
                });
            });
    }
</script>

